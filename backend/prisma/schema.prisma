generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  openid         String         @unique
  nickname       String
  avatar         String?
  city           String?
  bio            String?
  points         Int            @default(0)
  plants         Plant[]        @relation("PlantOwner")
  bredPlants     Plant[]        @relation("PlantBreeder")
  posts          Post[]
  comments       Comment[]
  likes          Like[]
  followings     Follow[]       @relation("FollowFollowing")
  followers      Follow[]       @relation("FollowFollower")
  messages       Message[]
  sentTrades     Trade[]        @relation("TradeOwner")
  receivedTrades Trade[]        @relation("TradeReceiver")
  conversations1 Conversation[] @relation("ConversationUser1")
  conversations2 Conversation[] @relation("ConversationUser2")
  plantHistories PlantHistory[] @relation("PlantHistoryOwner")
  reports        Report[]
  plantFavorites PlantFavorite[]
  stationFavorites StationFavorite[]
  stationApplications StationApplication[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Admin {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Station {
  id         Int      @id @default(autoincrement())
  stationCode String  @unique
  name       String
  address    String
  hours      String
  phone      String?
  imageEmoji String   @default("🏡")
  logoUrl    String?
  isActive   Boolean  @default(true) @ignore
  plants     Plant[]
  favorites  StationFavorite[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Plant {
  id             String          @id @default(cuid())
  plantCode      String          @unique
  name           String
  species        String
  source         String          @default("donation")
  breederId      String
  generation     Int             @default(1)
  wanderCount    Int             @default(0)
  status         PlantStatus     @default(ACTIVE)
  listStatus     PlantListStatus @default(NONE)
  currentOwnerId String
  stationId      Int?
  description    String?         @db.Text
  imageEmoji     String          @default("🌿")
  photos         Json?
  listedAt       DateTime?
  adoptedAt      DateTime?
  histories      PlantHistory[]
  posts          Post[]
  trades         Trade[]
  owner          User            @relation("PlantOwner", fields: [currentOwnerId], references: [id])
  breeder        User            @relation("PlantBreeder", fields: [breederId], references: [id])
  station        Station?        @relation(fields: [stationId], references: [id])
  favorites      PlantFavorite[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([stationId, listStatus])
  @@index([plantCode])
}

model PlantHistory {
  id        String        @id @default(cuid())
  plantId   String
  ownerId   String
  action    HistoryAction
  timestamp DateTime      @default(now())
  note      String?
  photoUrl  String?
  plant     Plant         @relation(fields: [plantId], references: [id])
  owner     User          @relation("PlantHistoryOwner", fields: [ownerId], references: [id])
}

model Post {
  id        String    @id @default(cuid())
  userId    String
  plantId   String?
  content   String
  images    Json?
  type      PostType
  comments  Comment[]
  likes     Like[]
  user      User      @relation(fields: [userId], references: [id])
  plant     Plant?    @relation(fields: [plantId], references: [id])
  createdAt DateTime  @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("FollowFollower", fields: [followerId], references: [id])
  following   User     @relation("FollowFollowing", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Trade {
  id           String      @id @default(cuid())
  plantId      String
  ownerId      String
  receiverId   String
  type         TradeType
  status       TradeStatus @default(PENDING)
  offerContent String?
  plant        Plant       @relation(fields: [plantId], references: [id])
  owner        User        @relation("TradeOwner", fields: [ownerId], references: [id])
  receiver     User        @relation("TradeReceiver", fields: [receiverId], references: [id])
  createdAt    DateTime    @default(now())
  completedAt  DateTime?
}

model Conversation {
  id          String    @id @default(cuid())
  user1Id     String
  user2Id     String
  lastMessage String?
  unreadCount Int       @default(0)
  messages    Message[]
  user1       User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2       User      @relation("ConversationUser2", fields: [user2Id], references: [id])
  updatedAt   DateTime  @updatedAt

  @@unique([user1Id, user2Id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  createdAt      DateTime     @default(now())
}

model Report {
  id         String           @id @default(cuid())
  userId     String
  targetId   String
  targetType ReportTargetType
  reason     String
  status     ReportStatus     @default(PENDING)
  user       User             @relation(fields: [userId], references: [id])
  createdAt  DateTime         @default(now())
}

enum PlantStatus {
  ACTIVE
  ADOPTED
  DEAD
}

enum PlantListStatus {
  NONE
  AVAILABLE
}

enum HistoryAction {
  ADOPT
  GIFT
  TRADE
  WANDER
}

enum PostType {
  DAILY
  GROWTH
  WANDER
  TRADE
}

enum TradeType {
  EXCHANGE
  ADOPT
  FREE
}

enum TradeStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum ReportTargetType {
  POST
  COMMENT
  USER
}

enum ReportStatus {
  PENDING
  RESOLVED
  IGNORED
}

model PlantFavorite {
  id        String   @id @default(cuid())
  userId    String
  plantId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, plantId])
  @@index([userId])
}

model StationFavorite {
  id        String   @id @default(cuid())
  userId    String
  stationId Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, stationId])
  @@index([userId])
}

model StationApplication {
  id            String                     @id @default(cuid())
  userId        String?
  applicantName String
  phone         String
  stationName   String
  address       String
  hours         String?
  intro         String?                    @db.Text
  status        StationApplicationStatus   @default(PENDING)
  reviewNote    String?
  reviewedAt    DateTime?
  user          User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([status])
  @@index([userId])
}

enum StationApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
