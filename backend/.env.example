# =============================================================================
# PlantShow 本地开发环境配置
# =============================================================================
#
# 使用方式：
#   cp .env.example .env
#   按说明修改后启动：npm run backend:dev
#
# Docker 云服务器部署请用项目根目录的 .env.example，不是本文件
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库连接
# -----------------------------------------------------------------------------
# 本地 MySQL 示例（需先创建库 plant_show 并执行 prisma migrate）
DATABASE_URL="mysql://root:你的密码@localhost:3306/plant_show"

# 若使用 docker compose 仅启动 MySQL：
# DATABASE_URL="mysql://root:plant123@localhost:3306/plant_show"

# -----------------------------------------------------------------------------
# JWT 鉴权（本地可用简单值，生产必须改随机强密钥）
# -----------------------------------------------------------------------------
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"
ADMIN_JWT_SECRET="dev-admin-jwt-secret-change-in-production"
ADMIN_JWT_EXPIRES_IN="1d"
PORT=3000

# 本地开发可 false，允许 /api/auth/dev-login 调试登录
DISABLE_DEV_LOGIN=false

# -----------------------------------------------------------------------------
# 微信小程序登录
# -----------------------------------------------------------------------------
# 获取：微信公众平台 → 开发 → 开发管理 → 开发设置 → AppSecret
# AppID 需与 frontend/project.config.json 中 appid 一致
WECHAT_APPID="wx00965c2515dbd2f1"
WECHAT_SECRET="请填写微信小程序AppSecret"

# 未配置时：模拟器可用 dev-login；真机微信登录会失败

# -----------------------------------------------------------------------------
# 地图服务（地址转经纬度，二选一）
# -----------------------------------------------------------------------------
# 高德：lbs.amap.com → 应用管理 → 添加 Key → 服务平台选「Web 服务」
AMAP_KEY="请填写高德Web服务Key"

# 腾讯地图（可选，与 AMAP_KEY 二选一）
# TENCENT_MAP_KEY=""

# 未配置时：新建/更新中转站地址无法自动 geocoding，地图导航可能异常

# =============================================================================
# 本地开发快速检查
# =============================================================================
# [ ] MySQL 已启动，DATABASE_URL 可连接
# [ ] 已执行：cd backend && npx prisma migrate dev
# [ ] WECHAT_SECRET 已填（需要测微信登录时）
# [ ] AMAP_KEY 已填（需要测地址/导航时）
# =============================================================================
