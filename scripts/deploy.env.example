# 本机一键推送并远程升级时使用（复制为 deploy.env，勿提交 Git）
# cp scripts/deploy.env.example scripts/deploy.env

# ECS SSH 地址
ECS_HOST=root@123.57.244.162

# 服务器上项目路径
ECS_PATH=/root/PlantShow

# 远程升级模式: backend | all | none
# backend = 只构建 backend（默认，省内存）
# all     = backend + nginx
# none    = 只 push 代码，不在服务器执行升级
UPGRADE_MODE=backend
