# =============================================================================
# PlantShow 云服务器 Docker 部署配置
# =============================================================================
#
# 使用方式：
#   cp .env.example .env
#   nano .env          # 按下面说明逐项填写
#   bash scripts/deploy-prod.sh
#
# 注意：.env 含密钥，切勿提交到 Git
# =============================================================================

DOMAIN=plshow.cn

# -----------------------------------------------------------------------------
# MySQL 数据库
# -----------------------------------------------------------------------------
# MYSQL_ROOT_PASSWORD：数据库 root 密码，请改为强密码（字母+数字+符号，16位以上）
# MYSQL_DATABASE：库名，一般不用改
MYSQL_ROOT_PASSWORD=请改为强密码_例如_Ps9kL2mN8xQ4vR7w
MYSQL_DATABASE=plant_show

# -----------------------------------------------------------------------------
# JWT 鉴权密钥
# -----------------------------------------------------------------------------
# 用于签发用户/管理员登录 Token，请改为随机长字符串（可用 openssl rand -hex 32 生成）
# JWT_SECRET：小程序用户 Token
# ADMIN_JWT_SECRET：管理后台 Token（必须与 JWT_SECRET 不同）
JWT_SECRET=请改为随机字符串_用户JWT
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=请改为随机字符串_管理员JWT
ADMIN_JWT_EXPIRES_IN=1d

# -----------------------------------------------------------------------------
# 后端运行
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# 生产环境必须 true，禁止 /api/auth/dev-login 伪造登录
DISABLE_DEV_LOGIN=true

# 仅首次部署设为 true（创建 admin 账号和演示数据），成功后改为 false 并重启 backend
#   docker compose up -d backend
RUN_SEED=true

# -----------------------------------------------------------------------------
# 微信小程序登录（必填）
# -----------------------------------------------------------------------------
# 获取方式：
#   1. 登录 https://mp.weixin.qq.com/
#   2. 开发 → 开发管理 → 开发设置
#   3. 复制 AppID 和 AppSecret（重置后旧 Secret 立即失效）
#
# WECHAT_APPID：与 frontend/project.config.json 中 appid 一致
# WECHAT_SECRET：小程序密钥，只显示一次，请妥善保存
WECHAT_APPID=wxd2561ed5af0d21df
WECHAT_SECRET=请填写微信小程序AppSecret

# -----------------------------------------------------------------------------
# 高德地图（创建/更新中转站地址转经纬度，二选一）
# -----------------------------------------------------------------------------
# 获取方式：
#   1. 登录 https://lbs.amap.com/
#   2. 控制台 → 应用管理 → 我的应用 → 创建新应用
#   3. 添加 Key，服务平台必须选「Web 服务」（不是微信小程序）
#
# 也可用腾讯地图代替，取消下行注释并填写 TENCENT_MAP_KEY
AMAP_KEY=请填写高德Web服务Key
# TENCENT_MAP_KEY=

# -----------------------------------------------------------------------------
# HTTPS 证书（Let's Encrypt）
# -----------------------------------------------------------------------------
# 用于申请 SSL 证书，填写真实邮箱（到期/异常会通知）
# DNS 解析生效后执行：bash scripts/init-ssl.sh
CERTBOT_EMAIL=admin@plshow.cn

# =============================================================================
# 填写完成后的检查清单
# =============================================================================
# [ ] MYSQL_ROOT_PASSWORD 已改为强密码
# [ ] JWT_SECRET / ADMIN_JWT_SECRET 已改为随机值
# [ ] WECHAT_SECRET 已填写且与小程序 AppID 匹配
# [ ] AMAP_KEY 已填写（Web 服务类型）
# [ ] plshow.cn / www.plshow.cn 已解析到服务器 IP
# [ ] 微信公众平台 request 合法域名已添加 https://plshow.cn
# [ ] 首次部署成功后 RUN_SEED 改为 false
# =============================================================================
