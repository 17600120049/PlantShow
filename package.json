{
  "name": "plant-wander",
  "version": "1.0.0",
  "private": true,
  "description": "流浪植物驿站 — 微信小程序 + NestJS 后端 + 管理后台",
  "workspaces": [
    "backend",
    "admin-frontend"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev -w plant-wander-backend",
    "backend:build": "npm run build -w plant-wander-backend",
    "backend:seed": "npm run prisma:seed -w plant-wander-backend",
    "admin:dev": "npm run dev -w plant-wander-admin",
    "admin:build": "npm run build -w plant-wander-admin",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  }
}
