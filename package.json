{
  "name": "plant-show",
  "version": "1.0.0",
  "private": true,
  "description": "PlantShow — 微信小程序 + NestJS 后端 + 管理后台",
  "workspaces": [
    "backend",
    "admin-frontend"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev -w plant-show-backend",
    "backend:build": "npm run build -w plant-show-backend",
    "backend:seed": "npm run prisma:seed -w plant-show-backend",
    "admin:dev": "npm run dev -w plant-show-admin",
    "admin:build": "npm run build -w plant-show-admin",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:deploy": "docker compose up -d --build",
    "docker:prod": "bash scripts/deploy-prod.sh",
    "docker:upgrade": "bash scripts/upgrade-prod.sh",
    "docker:upgrade:all": "bash scripts/upgrade-prod.sh --all",
    "deploy:upgrade": "powershell -ExecutionPolicy Bypass -File scripts/push-upgrade.ps1",
    "deploy:push": "git push gitee main",
    "docker:ssl": "bash scripts/init-ssl.sh",
    "docker:logs": "docker compose logs -f"
  }
}
