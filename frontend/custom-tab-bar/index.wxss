.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 90rpx;
  background: #ffffff;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
}

/* 发布按钮样式 */
.tab-bar-item-publish {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.publish-btn {
  width: 76rpx;
  height: 76rpx;
  background: linear-gradient(135deg, #3a5a40 0%, #2d4a33 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(58, 90, 64, 0.25);
}

.publish-icon {
  font-size: 42rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}
