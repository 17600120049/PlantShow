/**
 * PlantShow — 设计令牌
 */

page {
  --color-primary: #2D4739;
  --color-primary-dark: #1A2E24;
  --color-primary-light: #3F5F4E;
  --color-secondary: #6B8B7A;
  --color-accent: #C4785A;
  --color-accent-soft: rgba(196, 120, 90, 0.14);
  --color-gold: #D4A017;
  --color-bg: #FAF9F7;
  --color-bg-warm: #F3F0EB;
  --color-bg-card: rgba(255, 255, 255, 0.88);
  --color-text: #1C1B19;
  --color-text-secondary: #6B6560;
  --color-text-tertiary: #9C9690;
  --color-border: rgba(45, 71, 57, 0.08);
  --shadow-sm: 0 2rpx 12rpx rgba(28, 27, 25, 0.04);
  --shadow-md: 0 8rpx 32rpx rgba(28, 27, 25, 0.07), 0 2rpx 8rpx rgba(28, 27, 25, 0.03);
  --shadow-lg: 0 20rpx 60rpx rgba(28, 27, 25, 0.09), 0 4rpx 16rpx rgba(28, 27, 25, 0.04);
  --radius-sm: 14rpx;
  --radius-md: 22rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --font-display: 'Noto Sans SC', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  --font-body: 'Noto Sans SC', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  --tab-bar-content-height: 84rpx;
  --page-tab-padding: calc(84rpx + constant(safe-area-inset-bottom) + 16rpx);
  --page-tab-padding: calc(84rpx + env(safe-area-inset-bottom) + 16rpx);
}

.glass {
  background: var(--color-bg-card);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* 液态玻璃 — 半透明渐变 + 高光 + 模糊 */
.glass-liquid {
  position: relative;
  overflow: hidden;
  background: linear-gradient(
    145deg,
    rgba(255, 255, 255, 0.78) 0%,
    rgba(255, 255, 255, 0.42) 42%,
    rgba(255, 255, 255, 0.55) 100%
  );
  box-shadow:
    0 10rpx 48rpx rgba(45, 71, 57, 0.07),
    0 2rpx 12rpx rgba(28, 27, 25, 0.04);
  backdrop-filter: blur(48rpx) saturate(170%);
  -webkit-backdrop-filter: blur(48rpx) saturate(170%);
}

.glass-liquid::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 55%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.55) 0%,
    rgba(255, 255, 255, 0.08) 100%
  );
  border-radius: inherit;
  pointer-events: none;
  z-index: 0;
}

.glass-liquid::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -25%;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(
    circle,
    rgba(255, 255, 255, 0.45) 0%,
    rgba(255, 255, 255, 0.12) 40%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

/* 植物 / 中转站卡片 — 增强玻璃立体感 */
.plant-card.glass-liquid,
.station-card.glass-liquid {
  background: linear-gradient(
    155deg,
    rgba(255, 255, 255, 0.94) 0%,
    rgba(255, 255, 255, 0.62) 36%,
    rgba(255, 255, 255, 0.48) 58%,
    rgba(248, 246, 243, 0.65) 100%
  );
  backdrop-filter: blur(56rpx) saturate(190%);
  -webkit-backdrop-filter: blur(56rpx) saturate(190%);
}

.station-card.glass-liquid {
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow:
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.9),
    inset 0 -2rpx 6rpx rgba(45, 71, 57, 0.02),
    0 14rpx 48rpx rgba(45, 71, 57, 0.055),
    0 6rpx 20rpx rgba(28, 27, 25, 0.035),
    0 2rpx 6rpx rgba(28, 27, 25, 0.02);
}

.plant-card.glass-liquid {
  overflow: hidden;
  border: none;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.1);
}

.station-card.glass-liquid::before {
  height: 52%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.78) 0%,
    rgba(255, 255, 255, 0.28) 50%,
    rgba(255, 255, 255, 0) 100%
  );
}

.plant-card.glass-liquid::before {
  height: 42%;
  border-radius: inherit;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.42) 22%,
    rgba(255, 255, 255, 0.14) 58%,
    rgba(255, 255, 255, 0) 100%
  );
}

.station-card.glass-liquid::after {
  top: -32%;
  right: -18%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(
    circle,
    rgba(255, 255, 255, 0.68) 0%,
    rgba(255, 255, 255, 0.22) 38%,
    transparent 70%
  );
}

.plant-card.glass-liquid::after {
  top: 0;
  right: 0;
  width: 200rpx;
  height: 150rpx;
  border-radius: inherit;
  background: radial-gradient(
    ellipse at 100% 0%,
    rgba(255, 255, 255, 0.38) 0%,
    rgba(255, 255, 255, 0.1) 42%,
    transparent 72%
  );
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-primary);
  letter-spacing: 1rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  border-radius: 3rpx;
}
