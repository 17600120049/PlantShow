/**
 * 流浪植物驿站 - 统一图标样式
 * 线性图标设计：2px线宽，圆角设计，主色 #2D4739
 */

/* ============ 图标基础类 ============ */

.icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-sm {
  width: 20px;
  height: 20px;
}

.icon-md {
  width: 24px;
  height: 24px;
}

.icon-lg {
  width: 32px;
  height: 32px;
}

.icon-xl {
  width: 40px;
  height: 40px;
}

/* ============ 首页图标 - Home ============ */
.icon-home, .icon-home-lg {
  position: relative;
}

/* 屋顶三角形 */
.icon-home::before,
.icon-home-lg::before {
  content: '';
  position: absolute;
  display: block;
  width: 0;
  height: 0;
  border-left: 16px solid transparent;
  border-right: 16px solid transparent;
  border-bottom: 20px solid currentColor;
}

/* 房子主体 */
.icon-home::after,
.icon-home-lg::after {
  content: '';
  position: absolute;
  display: block;
  background: currentColor;
  border-radius: 4px;
}

.icon-home {
  width: 32px;
  height: 32px;
}
.icon-home::before {
  border-left-width: 12px;
  border-right-width: 12px;
  border-bottom-width: 14px;
  top: 0;
  left: 4px;
}
.icon-home::after {
  width: 28px;
  height: 16px;
  top: 14px;
  left: 2px;
}

.icon-home-lg {
  width: 44px;
  height: 44px;
}
.icon-home-lg::before {
  border-left-width: 16px;
  border-right-width: 16px;
  border-bottom-width: 20px;
  top: 0;
  left: 6px;
}
.icon-home-lg::after {
  width: 40px;
  height: 22px;
  top: 20px;
  left: 2px;
}

/* ============ 心形图标 - Heart ============ */
.icon-heart, .icon-heart-lg {
  position: relative;
}

.icon-heart::before,
.icon-heart-lg::before {
  content: '';
  position: absolute;
  display: block;
  border: 2px solid currentColor;
  border-bottom: none;
  border-radius: 50% 50% 0 0;
  transform: rotate(-45deg);
}

.icon-heart::after,
.icon-heart-lg::after {
  content: '';
  position: absolute;
  display: block;
  border: 2px solid currentColor;
  border-bottom: none;
  border-radius: 50% 50% 0 0;
  transform: rotate(45deg);
}

.icon-heart {
  width: 24px;
  height: 24px;
}
.icon-heart::before {
  width: 12px;
  height: 12px;
  top: 4px;
  right: 6px;
}
.icon-heart::after {
  width: 12px;
  height: 12px;
  top: 4px;
  left: 6px;
}

.icon-heart-lg {
  width: 32px;
  height: 32px;
}
.icon-heart-lg::before {
  width: 16px;
  height: 16px;
  top: 6px;
  right: 8px;
  border-width: 2.5px;
}
.icon-heart-lg::after {
  width: 16px;
  height: 16px;
  top: 6px;
  left: 8px;
  border-width: 2.5px;
}

/* 心形填充 */
.icon-heart-fill {
  width: 24px;
  height: 24px;
  position: relative;
  color: #D67D5C;
}
.icon-heart-fill::before,
.icon-heart-fill::after {
  content: '';
  position: absolute;
  display: block;
  background: currentColor;
  border-radius: 50% 50% 0 0;
}
.icon-heart-fill::before {
  width: 12px;
  height: 12px;
  top: 4px;
  right: 6px;
  transform: rotate(-45deg);
}
.icon-heart-fill::after {
  width: 12px;
  height: 12px;
  top: 4px;
  left: 6px;
  transform: rotate(45deg);
}

/* ============ 用户图标 - User ============ */
.icon-user, .icon-user-lg {
  position: relative;
}

.icon-user::before,
.icon-user-lg::before {
  content: '';
  position: absolute;
  display: block;
  border: 2px solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.icon-user::after,
.icon-user-lg::after {
  content: '';
  position: absolute;
  display: block;
  border: 2px solid currentColor;
  border-top: none;
  border-radius: 0 0 50% 50%;
  box-sizing: border-box;
}

.icon-user {
  width: 24px;
  height: 24px;
}
.icon-user::before {
  width: 12px;
  height: 12px;
  top: 2px;
  left: 6px;
}
.icon-user::after {
  width: 18px;
  height: 10px;
  bottom: 2px;
  left: 3px;
}

.icon-user-lg {
  width: 32px;
  height: 32px;
}
.icon-user-lg::before {
  width: 16px;
  height: 16px;
  top: 3px;
  left: 8px;
  border-width: 2.5px;
}
.icon-user-lg::after {
  width: 24px;
  height: 12px;
  bottom: 3px;
  left: 4px;
  border-width: 2.5px;
}

/* ============ 植物图标 - Leaf ============ */
.icon-plant {
  width: 24px;
  height: 24px;
  position: relative;
}
.icon-plant::before {
  content: '';
  position: absolute;
  width: 8px;
  height: 16px;
  border: 2px solid currentColor;
  border-radius: 50% 0 50% 50%;
  transform: rotate(-30deg);
  top: 2px;
  left: 8px;
}
.icon-plant::after {
  content: '';
  position: absolute;
  width: 2px;
  height: 8px;
  background: currentColor;
  bottom: 2px;
  left: 50%;
  transform: translateX(-50%);
}

/* ============ 礼物图标 - Gift ============ */
.icon-gift {
  width: 24px;
  height: 24px;
  position: relative;
}
.icon-gift::before {
  content: '';
  position: absolute;
  width: 18px;
  height: 14px;
  border: 2px solid currentColor;
  border-radius: 3px;
  top: 5px;
  left: 3px;
}
.icon-gift::after {
  content: '';
  position: absolute;
  width: 8px;
  height: 6px;
  border: 2px solid currentColor;
  border-bottom: none;
  border-radius: 4px 4px 0 0;
  top: 2px;
  left: 8px;
}

/* ============ 星星图标 - Star ============ */
.icon-star {
  width: 24px;
  height: 24px;
  position: relative;
}
.icon-star::before {
  content: '★';
  font-size: 20px;
  color: currentColor;
  line-height: 1;
}

.icon-star-fill {
  width: 24px;
  height: 24px;
  position: relative;
  color: #FFD700;
}
.icon-star-fill::before {
  content: '★';
  font-size: 20px;
  color: currentColor;
  line-height: 1;
}

/* ============ 设置图标 - Settings ============ */
.icon-settings {
  width: 24px;
  height: 24px;
  position: relative;
}
.icon-settings::before {
  content: '';
  position: absolute;
  width: 16px;
  height: 16px;
  border: 2px solid currentColor;
  border-radius: 50%;
  top: 4px;
  left: 4px;
}
.icon-settings::after {
  content: '';
  position: absolute;
  width: 4px;
  height: 4px;
  background: currentColor;
  border-radius: 50%;
  top: 10px;
  left: 10px;
}

/* ============ 箭头图标 ============ */
.icon-arrow-right {
  width: 20px;
  height: 20px;
  position: relative;
}
.icon-arrow-right::before {
  content: '';
  position: absolute;
  width: 8px;
  height: 8px;
  border-top: 2px solid currentColor;
  border-right: 2px solid currentColor;
  transform: rotate(45deg);
  top: 5px;
  left: 4px;
}

.icon-arrow-left {
  width: 20px;
  height: 20px;
  position: relative;
}
.icon-arrow-left::before {
  content: '';
  position: absolute;
  width: 8px;
  height: 8px;
  border-bottom: 2px solid currentColor;
  border-left: 2px solid currentColor;
  transform: rotate(45deg);
  top: 5px;
  left: 4px;
}

/* ============ 扫码图标 - Scan ============ */
.icon-scan {
  width: 24px;
  height: 24px;
  position: relative;
}
.icon-scan::before {
  content: '';
  position: absolute;
  width: 18px;
  height: 18px;
  border: 2px solid currentColor;
  border-radius: 4px;
  top: 3px;
  left: 3px;
}
.icon-scan::after {
  content: '';
  position: absolute;
  width: 6px;
  height: 6px;
  border: 2px solid currentColor;
  border-radius: 50%;
  bottom: 5px;
  right: 5px;
}

/* ============ 二维码图标 - QrCode ============ */
.icon-qrcode {
  width: 24px;
  height: 24px;
  position: relative;
}
.icon-qrcode::before {
  content: '';
  position: absolute;
  width: 18px;
  height: 18px;
  border: 2px solid currentColor;
  border-radius: 3px;
  top: 3px;
  left: 3px;
}
.icon-qrcode::after {
  content: '';
  position: absolute;
  width: 4px;
  height: 4px;
  background: currentColor;
  top: 6px;
  left: 6px;
  box-shadow: 6px 0 0 currentColor, 0 6px 0 currentColor, 6px 6px 0 currentColor;
}

/* ============ 白色版本图标 ============ */
.icon-white-scan,
.icon-white-qrcode {
  width: 40px;
  height: 40px;
  position: relative;
  color: #ffffff;
}

.icon-white-scan::before {
  content: '';
  position: absolute;
  width: 32px;
  height: 32px;
  border: 3px solid currentColor;
  border-radius: 6px;
  top: 4px;
  left: 4px;
}
.icon-white-scan::after {
  content: '';
  position: absolute;
  width: 10px;
  height: 10px;
  border: 3px solid currentColor;
  border-radius: 50%;
  bottom: 6px;
  right: 6px;
}

.icon-white-qrcode::before {
  content: '';
  position: absolute;
  width: 32px;
  height: 32px;
  border: 3px solid currentColor;
  border-radius: 5px;
  top: 4px;
  left: 4px;
}
.icon-white-qrcode::after {
  content: '';
  position: absolute;
  width: 6px;
  height: 6px;
  background: currentColor;
  top: 8px;
  left: 8px;
  box-shadow: 10px 0 0 currentColor, 0 10px 0 currentColor, 10px 10px 0 currentColor;
}

/* ============ 图标颜色类 ============ */
.icon-primary {
  color: #2D4739;
}

.icon-secondary {
  color: #8b8680;
}

.icon-accent {
  color: #D67D5C;
}

.icon-white {
  color: #ffffff;
}

.icon-gold {
  color: #FFD700;
}

/* ============ 图标背景容器 ============ */
.icon-bg {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(45, 71, 57, 0.1);
}

.icon-bg-lg {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
}

.icon-bg-light {
  background: rgba(255, 255, 255, 0.2);
}

/* ============ 底部导航图标容器 ============ */
.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
