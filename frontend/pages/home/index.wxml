<view class="page">
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-bg-shape"></view>
    <view class="logo-section">
      <view class="logo-text">
        <text class="logo-title">流浪植物中转站</text>
        <text class="logo-slogan">让每一株植物都能找到下一位主人</text>
      </view>
    </view>
  </view>

  <view class="function-section">
    <view class="function-card donate-card" bindtap="goToScanDonate">
      <view class="function-icon-wrap">
        <pw-icon name="scan-line" size="48" color="#FFFFFF" strokeWidth="2" />
      </view>
      <view class="function-info">
        <text class="function-title">扫码送养植物</text>
        <text class="function-desc">扫描中转站二维码送养</text>
      </view>
      <pw-icon name="chevron-right" size="36" color="rgba(255,255,255,0.75)" strokeWidth="2" />
    </view>
    <view class="function-card adopt-card" bindtap="goToScanAdopt">
      <view class="function-icon-wrap">
        <pw-icon name="qr-code" size="48" color="#FFFFFF" strokeWidth="2" />
      </view>
      <view class="function-info">
        <text class="function-title">扫码领取植物</text>
        <text class="function-desc">领养植物，开启新缘分</text>
      </view>
      <pw-icon name="chevron-right" size="36" color="rgba(255,255,255,0.75)" strokeWidth="2" />
    </view>
  </view>

  <view class="load-error glass" wx:if="{{loadError}}">
    <text>{{loadError}}</text>
    <text class="load-error-hint">请确认后端已启动，并在开发者工具中勾选「不校验合法域名」</text>
  </view>

  <view class="section section-plants">
    <view class="section-header">
      <text class="section-title">最新植物</text>
      <view class="section-more" bindtap="viewAllPlants">
        <text>查看全部</text>
        <pw-icon name="chevron-right" size="28" color="#9C9690" strokeWidth="2" />
      </view>
    </view>
    <scroll-view class="plant-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="plant-scroll-inner">
        <view class="plant-card glass-liquid" wx:for="{{ newPlants }}" wx:key="id" bindtap="goToPlantDetail" data-id="{{ item.id }}">
          <view class="plant-image-wrap">
            <image wx:if="{{item.photoUrl}}" class="plant-photo-cover" src="{{item.photoUrl}}" mode="aspectFill" />
            <view wx:else class="plant-emoji">{{ item.image }}</view>
            <view class="plant-image-glass"></view>
          </view>
          <view class="plant-info">
            <text class="plant-name">{{ item.name }}</text>
            <text class="plant-category">{{ item.category }}</text>
            <view class="plant-footer">
              <text class="plant-station">{{ item.station }}</text>
              <view class="plant-status-tag">{{ item.status }}</view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section section-stations">
    <view class="section-header">
      <text class="section-title">附近中转站</text>
      <view class="section-more" bindtap="viewAllStations">
        <text>查看全部</text>
        <pw-icon name="chevron-right" size="28" color="#9C9690" strokeWidth="2" />
      </view>
    </view>
    <view class="station-list">
      <view class="station-card glass-liquid" wx:for="{{ stations }}" wx:key="id" bindtap="goToStationDetail" data-id="{{ item.id }}">
        <view class="station-logo-wrap">
          <image wx:if="{{item.logoUrl}}" class="station-logo" src="{{item.logoUrl}}" mode="aspectFill" />
          <view wx:else class="station-image">{{ item.image }}</view>
        </view>
        <view class="station-info">
          <view class="station-header">
            <text class="station-name">{{ item.name }}</text>
            <view class="station-status {{ item.isActive ? 'status-open' : 'status-closed' }}">
              {{ item.isActive ? '营业中' : '休息中' }}
            </view>
          </view>
          <view class="station-details">
            <view class="station-address-row">
              <pw-icon name="map-pin" size="24" color="#9C9690" strokeWidth="1.8" />
              <text class="station-address">{{ item.address }}</text>
              <view
                class="station-nav-icon-btn"
                wx:if="{{ item.address }}"
                catchtap="openStationNavigation"
                data-id="{{ item.id }}"
              >
                <pw-icon name="navigation" size="28" color="#3F5F4E" strokeWidth="1.8" />
              </view>
            </view>
            <view class="station-meta">
              <view class="meta-item">
                <pw-icon name="clock" size="24" color="#9C9690" strokeWidth="1.8" />
                <text>{{ item.hours }}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="station-plants">
          <text class="plants-count">{{ item.plants }}</text>
          <text class="plants-label">株植物</text>
        </view>
      </view>
    </view>
  </view>
</view>
