<view class="page">
  <!-- 顶部区域 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="logo-section">
      <view class="logo-icon-wrap"><view class="logo-icon"></view></view>
      <view class="logo-text">
        <text class="logo-title">流浪植物驿站</text>
        <text class="logo-slogan">让每一株植物都能找到下一位主人</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="function-section">
    <view class="function-card donate-card" bindtap="goToScanDonate">
      <view class="function-icon-wrap donate-icon">
        <view class="icon-white-scan"></view>
      </view>
      <view class="function-info">
        <text class="function-title">扫码送养植物</text>
        <text class="function-desc">捐赠植物，获得积分</text>
      </view>
      <view class="function-arrow">→</view>
    </view>
    <view class="function-card adopt-card" bindtap="goToScanAdopt">
      <view class="function-icon-wrap adopt-icon">
        <view class="icon-white-qrcode"></view>
      </view>
      <view class="function-info">
        <text class="function-title">扫码领取植物</text>
        <text class="function-desc">领养植物，开启新缘分</text>
      </view>
      <view class="function-arrow">→</view>
    </view>
  </view>

  <!-- 中转站列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">附近中转站</text>
      <text class="section-more" bindtap="viewAllStations">查看全部 ›</text>
    </view>
    <view class="station-list">
      <view class="station-card glass" wx:for="{{ stations }}" wx:key="id" bindtap="goToStationDetail" data-id="{{ item.id }}">
        <view class="station-image">{{ item.image }}</view>
        <view class="station-info">
          <view class="station-header">
            <text class="station-name">{{ item.name }}</text>
            <view class="station-status {{ item.isActive ? 'status-open' : 'status-closed' }}">
              {{ item.isActive ? '营业中' : '休息中' }}
            </view>
          </view>
          <text class="station-address">{{ item.address }}</text>
          <view class="station-meta">
            <text class="station-hours">{{ item.hours }}</text>
            <text class="station-distance">{{ item.distance }}</text>
          </view>
        </view>
        <view class="station-plants">
          <text class="plants-count">{{ item.plants }}</text>
          <text class="plants-label">株植物</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 最新植物 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最新植物</text>
      <text class="section-more" bindtap="viewAllPlants">查看全部 ›</text>
    </view>
    <scroll-view class="plant-scroll" scroll-x>
      <view class="plant-card glass" wx:for="{{ newPlants }}" wx:key="id" bindtap="goToPlantDetail" data-id="{{ item.id }}">
        <view class="plant-image-wrap">
          <view class="plant-emoji">{{ item.image }}</view>
        </view>
        <view class="plant-info">
          <text class="plant-name">{{ item.name }}</text>
          <text class="plant-category">{{ item.category }}</text>
          <view class="plant-footer">
            <text class="plant-station">{{ item.station }}</text>
            <view class="plant-status-tag">{{ item.status }}</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>