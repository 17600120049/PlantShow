/* 液态玻璃效果（不模糊文字版） */
.glass {
  position: relative;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.glass-light {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

/* 文字清晰保证 */
.glass text,
.glass view,
.glass input,
.glass-light text,
.glass-light view {
  position: relative;
  z-index: 1;
  text-shadow: none;
  filter: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf8f5 0%, #f0ebe3 100%);
  padding-bottom: 200rpx;
  overflow-x: hidden;
}

/* 自定义导航栏 */
.navbar {
  background: transparent;
  position: relative;
  z-index: 100;
  padding-top: 88rpx !important;
}

.nav-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.nav-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  max-width: 150rpx;
}

.navbar .nav-row .notification {
  position: relative !important;
  width: 72rpx !important;
  height: 72rpx !important;
  background: rgba(255, 255, 255, 0.9) !important;
  border-radius: 50% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05) !important;
  margin-left: 0 !important;
  visibility: visible !important;
  opacity: 1 !important;
}

.search-row {
  padding: 16rpx 30rpx 20rpx;
}

.search-box {
  width: 100%;
  flex: none;
}

.location {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 26rpx;
  color: #3a5a40;
  font-weight: 500;
  margin-right: 8rpx;
}

.location-arrow {
  font-size: 20rpx;
  color: #3a5a40;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 28rpx;
  color: #8b8680;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #3a3a3a;
}

.search-placeholder {
  color: #a8a39c;
  font-size: 26rpx;
}

.notification {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-left: 0;
}

.notif-icon {
  font-size: 32rpx;
}

.notif-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: #ff4757;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 28rpx;
  text-align: center;
}

/* Logo 区域 */
.logo-section {
  padding: 40rpx 30rpx 20rpx;
}

.logo-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #2d3e2f;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.logo-subtitle {
  font-size: 24rpx;
  color: #8b8680;
  font-style: italic;
  margin-top: 4rpx;
  letter-spacing: 4rpx;
}

/* Banner 卡片 */
.banner {
  margin: 30rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  min-height: 280rpx;
  box-sizing: border-box;
}

.banner-content {
  flex: 1;
  z-index: 2;
}

.banner-tag {
  display: inline-block;
  background: rgba(58, 90, 64, 0.1);
  color: #3a5a40;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2d3e2f;
  line-height: 1.4;
}

.banner-btn {
  display: inline-block;
  margin-top: 24rpx;
  background: #3a5a40;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(58, 90, 64, 0.3);
}

.banner-image {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.4;
  z-index: 1;
}

.leaf-decoration {
  font-size: 200rpx;
  transform: rotate(20deg);
}

/* 功能入口 */
.features {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  margin: 0 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.feature-text {
  font-size: 22rpx;
  color: #3a3a3a;
  font-weight: 500;
}

/* 区块 */
.section {
  margin-top: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d3e2f;
}

.section-more {
  font-size: 24rpx;
  color: #8b8680;
}

/* 推荐动态 */
.post-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.post-card {
  display: inline-block;
  width: 360rpx;
  margin: 0 10rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.post-image-wrap {
  position: relative;
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #e8f0e6 0%, #d4e4d0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-image {
  font-size: 100rpx;
}

.post-type {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.post-info {
  padding: 20rpx;
}

.post-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3e2f;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-author {
  font-size: 22rpx;
  color: #8b8680;
}

.post-likes {
  display: flex;
  align-items: center;
}

.like-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.like-num {
  font-size: 22rpx;
  color: #8b8680;
}

/* 最新流浪 */
.plant-list {
  padding: 0 20rpx;
}

.plant-item {
  display: flex;
  margin: 0 10rpx 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.plant-thumb {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #e8f0e6 0%, #d4e4d0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.plant-emoji-large {
  font-size: 90rpx;
}

.plant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.plant-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.plant-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3e2f;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.plant-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.tag-trade {
  background: rgba(58, 90, 64, 0.15);
  color: #3a5a40;
}

.tag-free {
  background: rgba(139, 134, 128, 0.15);
  color: #8b8680;
}

.plant-desc {
  font-size: 24rpx;
  color: #6b665e;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.plant-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.plant-tag-item {
  font-size: 22rpx;
  color: #8b8680;
}

.plant-author {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #d4e4d0 0%, #b8d4b0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.author-name {
  font-size: 22rpx;
  color: #6b665e;
}

.plant-action {
  display: flex;
  align-items: flex-end;
}

.action-btn {
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  white-space: nowrap;
}

.btn-trade {
  background: #3a5a40;
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(58, 90, 64, 0.3);
}

.btn-free {
  background: rgba(58, 90, 64, 0.1);
  color: #3a5a40;
  border: 1rpx solid rgba(58, 90, 64, 0.2);
}