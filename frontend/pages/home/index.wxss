.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 50%, #FAF9F7 100%);
  padding-bottom: var(--page-tab-padding);
  overflow-x: hidden;
}

.header {
  position: relative;
  padding: 32rpx 32rpx 40rpx;
  overflow: hidden;
}

.header-bg-shape {
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(45, 71, 57, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.logo-section {
  position: relative;
  z-index: 1;
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.logo-slogan {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
  font-weight: 400;
}

.function-section {
  padding: 0 32rpx;
  display: flex;
  gap: 20rpx;
}

.function-card {
  flex: 1;
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.function-card::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  pointer-events: none;
}

.donate-card {
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
}

.adopt-card {
  background: linear-gradient(145deg, #7A9A88 0%, #5A7A68 100%);
}

.function-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.18);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.function-info {
  flex: 1;
  min-width: 0;
}

.function-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

.function-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 6rpx;
}

.load-error {
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: rgba(196, 120, 90, 0.1);
  color: #9A4A2E;
  font-size: 26rpx;
  line-height: 1.5;
}

.load-error-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.section {
  margin-top: 48rpx;
  position: relative;
  overflow: hidden;
}

.section-stations::before,
.section-plants::before {
  content: '';
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(2rpx);
}

.section-stations::before {
  top: 80rpx;
  left: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(107, 139, 122, 0.14) 0%, transparent 70%);
}

.section-plants::before {
  top: 120rpx;
  right: -40rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(45, 71, 57, 0.1) 0%, transparent 70%);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.station-list {
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}

.station-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
  transition: transform 0.2s ease;
}

.station-card.glass-liquid {
  box-shadow: none;
}

.station-card:active {
  transform: scale(0.985);
}

.station-logo-wrap {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  margin-right: 24rpx;
  border-radius: var(--radius-md);
}

.station-image {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(145deg, rgba(232, 240, 234, 0.95) 0%, rgba(212, 228, 214, 0.85) 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.station-logo {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-md);
  display: block;
}

.plant-photo-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.station-info {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 1;
}

.station-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.station-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-status {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.status-open {
  background: rgba(45, 71, 57, 0.12);
  color: var(--color-primary);
}

.status-closed {
  background: rgba(156, 150, 144, 0.14);
  color: var(--color-text-tertiary);
}

.station-address-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.station-address {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.station-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.station-plants {
  text-align: center;
  margin-left: 16rpx;
  padding: 12rpx 0 12rpx 20rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.plants-count {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.plants-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.plant-scroll {
  width: 100%;
  position: relative;
  z-index: 1;
}

.plant-scroll-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.plant-card.glass-liquid {
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.plant-card.glass-liquid::before,
.plant-card.glass-liquid::after {
  content: none;
  display: none;
}

.plant-card {
  flex-shrink: 0;
  width: 280rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  transition: transform 0.2s ease;
  background: linear-gradient(
    145deg,
    rgba(255, 255, 255, 0.78) 0%,
    rgba(255, 255, 255, 0.55) 100%
  );
}

.plant-card:active {
  transform: scale(0.97);
}

.plant-image-wrap {
  position: relative;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(145deg, rgba(232, 240, 234, 0.95) 0%, rgba(212, 228, 214, 0.85) 100%);
  overflow: hidden;
}

.plant-image-glass {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 60rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(255, 255, 255, 0.35) 100%
  );
  pointer-events: none;
  z-index: 2;
}

.plant-emoji {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
  z-index: 1;
}

.plant-info {
  padding: 20rpx 22rpx 24rpx;
  position: relative;
  z-index: 1;
}

.plant-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 6rpx;
}

.plant-category {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 14rpx;
}

.plant-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plant-station {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 8rpx;
}

.plant-status-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  background: rgba(45, 71, 57, 0.1);
  color: var(--color-primary);
  border-radius: 20rpx;
  flex-shrink: 0;
}
