.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 50%, #FAF9F7 100%);
  padding-bottom: var(--page-tab-padding);
}

.header {
  position: relative;
  padding: 32rpx 32rpx 40rpx;
  overflow: hidden;
}

.header-bg-shape {
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(45, 71, 57, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.logo-section {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.logo-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(45, 71, 57, 0.25);
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.logo-slogan {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
  font-weight: 400;
}

.function-section {
  padding: 0 32rpx;
  display: flex;
  gap: 20rpx;
}

.function-card {
  flex: 1;
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.function-card::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  pointer-events: none;
}

.donate-card {
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
}

.adopt-card {
  background: linear-gradient(145deg, #7A9A88 0%, #5A7A68 100%);
}

.function-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.18);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.function-info {
  flex: 1;
  min-width: 0;
}

.function-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

.function-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 6rpx;
}

.section {
  margin-top: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.station-list {
  padding: 0 24rpx;
}

.station-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  transition: transform 0.2s ease;
}

.station-card:active {
  transform: scale(0.985);
}

.station-image {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(145deg, #E8F0EA 0%, #D4E4D6 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.station-info {
  flex: 1;
  min-width: 0;
}

.station-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.station-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-status {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.status-open {
  background: rgba(45, 71, 57, 0.1);
  color: var(--color-primary);
}

.status-closed {
  background: rgba(156, 150, 144, 0.12);
  color: var(--color-text-tertiary);
}

.station-address-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.station-address {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.station-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.station-plants {
  text-align: center;
  margin-left: 16rpx;
  padding-left: 20rpx;
  border-left: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.plants-count {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.plants-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.plant-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.plant-card {
  display: inline-block;
  width: 280rpx;
  margin: 0 8rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  vertical-align: top;
}

.plant-card:first-child {
  margin-left: 0;
}

.plant-image-wrap {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(145deg, #E8F0EA 0%, #D4E4D6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plant-emoji {
  font-size: 80rpx;
}

.plant-info {
  padding: 20rpx 22rpx 24rpx;
}

.plant-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 6rpx;
}

.plant-category {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 14rpx;
}

.plant-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plant-station {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 8rpx;
}

.plant-status-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  background: rgba(45, 71, 57, 0.08);
  color: var(--color-primary);
  border-radius: 20rpx;
  flex-shrink: 0;
}
