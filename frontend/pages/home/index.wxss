.glass {
  background: rgba(253, 252, 251, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FDFCFB 0%, #F5F2EE 100%);
  padding-bottom: 180rpx;
}

.header {
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, rgba(45, 71, 57, 0.08) 0%, transparent 100%);
}

.logo-section {
  display: flex;
  align-items: center;
}

.logo-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2D4739 0%, #1E3A2F 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.logo-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  color: #ffffff;
}

.logo-icon::before {
  content: '';
  position: absolute;
  width: 14px;
  height: 24px;
  border: 3px solid currentColor;
  border-radius: 50% 0 50% 50%;
  transform: rotate(-30deg);
  top: 2px;
  left: 8px;
}

.logo-icon::after {
  content: '';
  position: absolute;
  width: 3px;
  height: 12px;
  background: currentColor;
  bottom: 2px;
  left: 50%;
  transform: translateX(-50%);
}

.logo-text {
  display: flex;
  flex-direction: column;
}

.logo-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D4739;
  letter-spacing: 2rpx;
}

.logo-slogan {
  font-size: 22rpx;
  color: #8b8680;
  margin-top: 8rpx;
  font-style: italic;
}

.function-section {
  padding: 0 30rpx;
  margin-top: 20rpx;
  display: flex;
  gap: 20rpx;
}

.function-card {
  flex: 1;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.donate-card {
  background: linear-gradient(135deg, #2D4739 0%, #1E3A2F 100%);
}

.adopt-card {
  background: linear-gradient(135deg, #8DA390 0%, #6B8B7A 100%);
}

.function-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  margin-right: 20rpx;
}

.function-info {
  flex: 1;
}

.function-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.function-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.function-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  margin-top: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D4739;
}

.section-more {
  font-size: 24rpx;
  color: #8b8680;
}

.station-list {
  padding: 0 20rpx;
}

.station-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.station-image {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #E8F0E9 0%, #D4E4D0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 24rpx;
}

.station-info {
  flex: 1;
  min-width: 0;
}

.station-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.station-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D4739;
  flex: 1;
}

.station-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.status-open {
  background: rgba(45, 71, 57, 0.15);
  color: #2D4739;
}

.status-closed {
  background: rgba(139, 134, 128, 0.15);
  color: #8b8680;
}

.station-address {
  font-size: 24rpx;
  color: #6b665e;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-meta {
  display: flex;
  gap: 20rpx;
}

.station-hours, .station-distance {
  font-size: 22rpx;
  color: #8b8680;
}

.station-plants {
  text-align: center;
  margin-left: 20rpx;
}

.plants-count {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2D4739;
}

.plants-label {
  font-size: 20rpx;
  color: #8b8680;
}

.plant-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.plant-card {
  display: inline-block;
  width: 280rpx;
  margin: 0 10rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.plant-image-wrap {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #E8F0E9 0%, #D4E4D0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plant-emoji {
  font-size: 80rpx;
}

.plant-info {
  padding: 20rpx;
}

.plant-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2D4739;
  margin-bottom: 8rpx;
}

.plant-category {
  display: block;
  font-size: 22rpx;
  color: #8b8680;
  margin-bottom: 12rpx;
}

.plant-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plant-station {
  font-size: 20rpx;
  color: #6b665e;
}

.plant-status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(45, 71, 57, 0.1);
  color: #2D4739;
  border-radius: 16rpx;
}