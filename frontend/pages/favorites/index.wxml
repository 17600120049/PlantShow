<view class="page">
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <text class="page-title">我的收藏</text>
    <text class="page-subtitle">收藏的植物与中转站，含已领养内容</text>
  </view>

  <view class="tabs">
    <view class="tab-item {{ activeTab === 'plants' ? 'active' : '' }}" bindtap="setTab" data-tab="plants">
      <pw-icon name="leaf" size="32" color="{{ activeTab === 'plants' ? '#FFFFFF' : '#9C9690' }}" strokeWidth="2" />
      <text class="tab-text">收藏植物</text>
    </view>
    <view class="tab-item {{ activeTab === 'stations' ? 'active' : '' }}" bindtap="setTab" data-tab="stations">
      <pw-icon name="building-2" size="32" color="{{ activeTab === 'stations' ? '#FFFFFF' : '#9C9690' }}" strokeWidth="2" />
      <text class="tab-text">收藏中转站</text>
    </view>
  </view>

  <view class="load-error" wx:if="{{loadError}}">{{loadError}}</view>

  <view class="guest-state" wx:if="{{ !loggedIn }}">
    <view class="empty-icon-wrap">
      <pw-icon name="user" size="80" color="#2D4739" strokeWidth="1.6" />
    </view>
    <text class="empty-text">登录后查看收藏</text>
    <text class="empty-hint">收藏植物与中转站，方便随时查看</text>
    <view class="login-btn" bindtap="onLoginTap">微信快捷登录</view>
  </view>

  <view class="content" wx:elif="{{ loggedIn && activeTab === 'plants' }}">
    <view wx:if="{{ !loading && plants.length === 0 }}" class="empty-state">
      <view class="empty-icon-wrap">
        <pw-icon name="heart" size="80" color="#2D4739" strokeWidth="1.6" />
      </view>
      <text class="empty-text">暂无收藏植物</text>
      <text class="empty-hint">在植物详情页点击右上角爱心收藏</text>
    </view>
    <view wx:else class="plant-list">
      <view class="plant-card glass" wx:for="{{ plants }}" wx:key="id" bindtap="goToPlantDetail" data-id="{{ item.id }}">
        <view class="plant-image-wrap">
          <image wx:if="{{item.photoUrl}}" class="plant-photo" src="{{item.photoUrl}}" mode="aspectFill" />
          <view wx:else class="plant-emoji">{{ item.image }}</view>
        </view>
        <view class="plant-info">
          <text class="plant-name">{{ item.name }}</text>
          <text class="plant-category">{{ item.category }}</text>
          <view class="plant-footer">
            <text class="plant-station">{{ item.station || '暂无中转站' }}</text>
            <view class="plant-status-tag {{ item.status === '已领养' ? 'adopted' : '' }}">{{ item.status }}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="content" wx:elif="{{ loggedIn && activeTab === 'stations' }}">
    <view wx:if="{{ !loading && stations.length === 0 }}" class="empty-state">
      <view class="empty-icon-wrap">
        <pw-icon name="heart" size="80" color="#2D4739" strokeWidth="1.6" />
      </view>
      <text class="empty-text">暂无收藏中转站</text>
      <text class="empty-hint">在中转站详情页点击右上角爱心收藏</text>
    </view>
    <view wx:else class="station-list">
      <view class="station-card glass" wx:for="{{ stations }}" wx:key="id" bindtap="goToStationDetail" data-id="{{ item.id }}">
        <image wx:if="{{item.logoUrl}}" class="station-logo" src="{{item.logoUrl}}" mode="aspectFill" />
        <view wx:else class="station-image">{{ item.image }}</view>
        <view class="station-info">
          <text class="station-name">{{ item.name }}</text>
          <text class="station-address">{{ item.address }}</text>
          <view class="station-meta">
            <text class="station-plants">{{ item.plants }}株待领养</text>
            <text class="station-status {{ item.isActive ? 'open' : 'closed' }}">{{ item.isActive ? '营业中' : '休息中' }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
