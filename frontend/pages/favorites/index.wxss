.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 100%);
  padding-bottom: var(--page-tab-padding);
}

.navbar {
  padding: 24rpx 32rpx 32rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.tabs {
  display: flex;
  margin: 0 32rpx 32rpx;
  background: rgba(45, 71, 57, 0.05);
  border-radius: var(--radius-lg);
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 18rpx 16rpx;
  border-radius: var(--radius-md);
  transition: all 0.25s ease;
}

.tab-item.active {
  background: var(--color-primary);
  box-shadow: 0 8rpx 24rpx rgba(45, 71, 57, 0.2);
}

.tab-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-tertiary);
}

.tab-item.active .tab-text {
  color: #ffffff;
  font-weight: 600;
}

.content {
  padding: 0 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: rgba(45, 71, 57, 0.06);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 12rpx;
}

.plant-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plant-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: var(--radius-lg);
}

.plant-image-wrap {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(145deg, #E8F0EA 0%, #D4E4D6 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plant-emoji {
  font-size: 64rpx;
}

.plant-info {
  flex: 1;
  min-width: 0;
  padding: 0 20rpx;
}

.plant-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plant-category {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 12rpx;
}

.plant-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.plant-station {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.plant-status-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  background: rgba(45, 71, 57, 0.08);
  color: var(--color-primary);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.plant-action {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.station-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.station-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: var(--radius-lg);
}

.station-image {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(145deg, #E8F0EA 0%, #D4E4D6 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  flex-shrink: 0;
}

.station-info {
  flex: 1;
  min-width: 0;
  padding: 0 20rpx;
}

.station-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-address {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-meta {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.station-action {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-accent-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
