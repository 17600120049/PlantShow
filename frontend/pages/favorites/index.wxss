.page {
  min-height: 100vh;
  background: #FDFCFB;
  padding-bottom: 180rpx;
}

.header {
  padding: 60rpx 30rpx 30rpx;
  background: linear-gradient(180deg, rgba(45, 71, 57, 0.08) 0%, transparent 100%);
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2D4739;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8b8680;
  margin-top: 10rpx;
}

.tab-bar {
  display: flex;
  margin: 0 30rpx;
  background: rgba(45, 71, 57, 0.05);
  border-radius: 20rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8b8680;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #2D4739;
  color: #ffffff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(45, 71, 57, 0.08);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon {
  width: 60rpx;
  height: 60rpx;
  position: relative;
  color: #2D4739;
}

.empty-icon.plant::before {
  content: '';
  position: absolute;
  width: 20px;
  height: 36px;
  border: 3px solid currentColor;
  border-radius: 50% 0 50% 50%;
  transform: rotate(-30deg);
  top: 4px;
  left: 12px;
}

.empty-icon.plant::after {
  content: '';
  position: absolute;
  width: 3px;
  height: 16px;
  background: currentColor;
  bottom: 4px;
  left: 50%;
  transform: translateX(-50%);
}

.empty-icon.home::before {
  content: '';
  position: absolute;
  width: 36px;
  height: 28px;
  border: 3px solid currentColor;
  border-bottom: none;
  border-radius: 8px 8px 0 0;
  top: 8px;
  left: 6px;
}

.empty-icon.home::after {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 10px;
  background: currentColor;
  border-radius: 0 0 4px 4px;
  bottom: 6px;
}

.empty-text {
  font-size: 28rpx;
  color: #8b8680;
  text-align: center;
}

.list-container {
  padding: 20rpx;
}

.card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: rgba(253, 252, 251, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.card-image {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #E8F0E9 0%, #D4E4D0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 24rpx;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D4739;
  display: block;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #8b8680;
  display: block;
}

.card-extra {
  text-align: center;
  margin-left: 20rpx;
}

.card-count {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D4739;
  display: block;
}

.card-label {
  font-size: 20rpx;
  color: #8b8680;
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(214, 125, 92, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.remove-btn .icon-heart-fill {
  width: 28rpx;
  height: 28rpx;
}

.plant-card {
  width: calc(50% - 10rpx);
  display: inline-block;
  margin: 0 5rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(253, 252, 251, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.plant-image-wrap {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #E8F0E9 0%, #D4E4D0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plant-emoji {
  font-size: 72rpx;
}

.plant-info {
  padding: 20rpx;
}

.plant-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D4739;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plant-category {
  font-size: 22rpx;
  color: #8b8680;
  display: block;
  margin-bottom: 12rpx;
}

.plant-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(45, 71, 57, 0.1);
  color: #2D4739;
  border-radius: 16rpx;
}

.plant-remove-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.plant-remove-btn .icon-heart-fill {
  width: 24rpx;
  height: 24rpx;
}