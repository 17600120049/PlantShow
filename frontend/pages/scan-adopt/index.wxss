@import "../scan-donate/index.wxss";

.hero {
  background: linear-gradient(145deg, #7A9A88 0%, #5A7A68 100%);
}

.scan-btn.adopt {
  background: linear-gradient(135deg, #7A9A88 0%, #5A7A68 100%);
  box-shadow: 0 8rpx 24rpx rgba(90, 122, 104, 0.3);
}

.step-num.adopt {
  background: #6B8B7A;
}

.demo-card {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
}

.demo-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
}

.demo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.demo-item {
  padding: 16rpx 28rpx;
  background: rgba(107, 139, 122, 0.12);
  color: var(--color-primary);
  font-size: 26rpx;
  border-radius: 999rpx;
}

.station-header {
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 32rpx;
}

.station-emoji {
  width: 88rpx;
  height: 88rpx;
  background: rgba(107, 139, 122, 0.15);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.station-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.station-address {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.station-hours {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.station-qr {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  background: #fff;
  padding: 8rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--color-secondary);
}

.plant-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.plant-item.selected {
  border-color: #6B8B7A;
  background: rgba(107, 139, 122, 0.08);
}

.plant-emoji {
  width: 80rpx;
  height: 80rpx;
  background: rgba(107, 139, 122, 0.12);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.plant-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.plant-category {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.plant-time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.plant-check {
  width: 44rpx;
  height: 44rpx;
  background: #6B8B7A;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: auto;
}

.empty-card {
  padding: 64rpx 32rpx;
  text-align: center;
  border-radius: var(--radius-lg);
  margin-bottom: 32rpx;
}

.empty-emoji {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.primary-btn.adopt {
  background: linear-gradient(135deg, #7A9A88 0%, #5A7A68 100%);
  box-shadow: 0 8rpx 24rpx rgba(90, 122, 104, 0.25);
}

.adopt-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(107, 139, 122, 0.1);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-primary);
}

.success-icon.adopt {
  background: linear-gradient(135deg, #7A9A88, #5A7A68);
}

.success-station {
  text-align: center;
  padding: 24rpx;
  background: rgba(107, 139, 122, 0.1);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-primary);
}

.station-addr {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}
