@import "../../styles/detail-page.wxss";

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 50%, #FAF9F7 100%);
  padding: 0 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.loading-state {
  margin-top: 120rpx;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.load-error {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #9A4A2E;
  text-align: center;
  line-height: 1.5;
}

.list-view {
  margin-top: 24rpx;
}

.list-hint {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.station-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
}

.station-card-logo,
.station-card-emoji {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(45, 71, 57, 0.08);
  font-size: 40rpx;
}

.station-card-logo image {
  width: 100%;
  height: 100%;
}

.station-card-info {
  flex: 1;
  min-width: 0;
}

.station-card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.station-card-address {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-card-meta {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.station-card-hours {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.station-card-status {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.station-card-status.open {
  background: rgba(45, 71, 57, 0.12);
  color: var(--color-primary);
}

.station-card-status.closed {
  background: rgba(156, 150, 144, 0.16);
  color: var(--color-text-tertiary);
}

.intro-card,
.manage-panel,
.auto-panel,
.error-panel {
  margin-top: 24rpx;
  padding: 40rpx 32rpx;
  border-radius: var(--radius-xl);
}

.manage-panel {
  display: flex;
  flex-direction: column;
}

.auto-panel {
  display: flex;
  flex-direction: column;
}

.detail-view {
  margin-top: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.label.inline {
  margin-bottom: 0;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid var(--color-border);
  font-size: 28rpx;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
  margin-top: -8rpx;
  margin-bottom: 12rpx;
}

.field-hint.warn {
  color: #9A4A2E;
}

.sync-status {
  margin: 8rpx 0 20rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  background: rgba(45, 71, 57, 0.06);
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-btn::after {
  border: none;
}

.rescan-link-wrap {
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.intro-title {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.intro-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

.scan-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.scan-link-wrap {
  margin-top: 8rpx;
  text-align: center;
}

.scan-link,
.rescan-link {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.station-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.station-name {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.station-status {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.station-status.open {
  background: rgba(45, 71, 57, 0.12);
  color: var(--color-primary);
}

.station-status.closed {
  background: rgba(156, 150, 144, 0.16);
  color: var(--color-text-tertiary);
}

.station-hours {
  width: 100%;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.station-hint {
  width: 100%;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.action-row {
  width: 100%;
  margin-top: 36rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(45, 71, 57, 0.12);
  background: rgba(255, 255, 255, 0.72);
  color: var(--color-text-secondary);
}

.action-btn.open.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #ffffff;
}

.action-btn.closed.active {
  background: rgba(156, 150, 144, 0.22);
  border-color: rgba(156, 150, 144, 0.3);
  color: var(--color-text);
}

.error-panel {
  align-items: stretch;
}

.auto-info-meta,
.sync-message {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.sync-message {
  color: var(--color-primary);
}

.list-sync {
  display: block;
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.refresh-sync {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}
