.page {
  min-height: 100vh;
  background: transparent;
}

.overlay {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx;
  background: rgba(26, 46, 36, 0.52);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.modal {
  width: 100%;
  max-width: 640rpx;
  padding: 48rpx 40rpx 40rpx;
  border-radius: var(--radius-xl);
}

.modal-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 auto 36rpx;
  padding: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(45, 71, 57, 0.08);
  border: 3rpx dashed rgba(45, 71, 57, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--color-secondary);
}

.nickname-field {
  margin-bottom: 36rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.nickname-input {
  height: 88rpx;
  padding: 0 28rpx;
  background: rgba(139, 134, 128, 0.08);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  color: var(--color-text);
}

.nickname-placeholder {
  color: var(--color-text-tertiary);
}

.primary-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background: linear-gradient(135deg, #3F5F4E 0%, #2D4739 100%) !important;
  color: #ffffff !important;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(45, 71, 57, 0.25);
}

.primary-btn-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.primary-btn--inactive {
  background: linear-gradient(135deg, #6B8B7A 0%, #5A7A69 100%) !important;
  box-shadow: 0 4rpx 16rpx rgba(45, 71, 57, 0.12);
}

.primary-btn::after {
  border: none;
}

.primary-btn[disabled] {
  opacity: 1 !important;
  background: linear-gradient(135deg, #8FA898 0%, #7A9688 100%) !important;
  box-shadow: none;
}

.primary-btn[disabled] .primary-btn-text {
  color: #ffffff;
}

.skip-btn {
  margin-top: 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  padding: 12rpx 0;
}
