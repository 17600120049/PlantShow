/* 液态玻璃效果（不模糊文字版） */
.glass {
  position: relative;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.glass-light {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

/* 文字清晰保证 */
.glass text,
.glass view,
.glass input,
.glass-light text,
.glass-light view {
  position: relative;
  z-index: 1;
  text-shadow: none;
  filter: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf8f5 0%, #f0ebe3 100%);
  padding-bottom: 200rpx;
}

.navbar {
  background: transparent;
  padding-top: 60rpx;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2d3e2f;
}

.filter-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.filter-icon {
  font-size: 32rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6b665e;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.category-item.active {
  background: #3a5a40;
  color: #ffffff;
  border: 1rpx solid #3a5a40;
  box-shadow: 0 4rpx 12rpx rgba(58, 90, 64, 0.3);
}

.plant-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 20rpx;
}

.grid-card {
  width: calc(50% - 10rpx);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-image {
  position: relative;
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #e8f0e6 0%, #d4e4d0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-emoji {
  font-size: 100rpx;
}

.card-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
}

.tag-trade {
  background: rgba(58, 90, 64, 0.85);
  color: #ffffff;
}

.tag-free {
  background: rgba(255, 255, 255, 0.9);
  color: #3a5a40;
}

.card-content {
  padding: 20rpx;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3e2f;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #8b8680;
  margin-bottom: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-user {
  display: flex;
  align-items: center;
}

.user-mini-avatar {
  width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #d4e4d0 0%, #b8d4b0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  margin-right: 8rpx;
}

.user-mini-name {
  font-size: 20rpx;
  color: #6b665e;
}

.card-location {
  font-size: 20rpx;
  color: #8b8680;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
}

.load-text {
  font-size: 24rpx;
  color: #a8a39c;
}