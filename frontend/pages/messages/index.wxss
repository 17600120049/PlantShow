/* 液态玻璃效果（不模糊文字版） */
.glass {
  position: relative;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.glass-light {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

/* 文字清晰保证 */
.glass text,
.glass view,
.glass input,
.glass-light text,
.glass-light view {
  position: relative;
  z-index: 1;
  text-shadow: none;
  filter: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf8f5 0%, #f0ebe3 100%);
  padding-bottom: 200rpx;
}

.navbar {
  background: transparent;
  padding-top: 60rpx;
}

.nav-content {
  padding: 20rpx 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2d3e2f;
}

.message-tabs {
  display: flex;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #6b665e;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.tab-item.active {
  background: #3a5a40;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(58, 90, 64, 0.3);
}

.tab-text {
  font-weight: 500;
}

.tab-badge {
  position: absolute;
  top: 10rpx;
  right: 30rpx;
  background: #ff4757;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
}

.chat-list, .notify-list, .system-list {
  padding: 0 20rpx;
}

.chat-item, .notify-item, .system-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.chat-avatar {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #d4e4d0 0%, #b8d4b0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.chat-info {
  flex: 1;
  min-width: 0;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.chat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3e2f;
}

.chat-time {
  font-size: 22rpx;
  color: #a8a39c;
}

.chat-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-message {
  font-size: 26rpx;
  color: #6b665e;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.unread-badge {
  background: #ff4757;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.notify-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.notify-icon.like {
  background: rgba(255, 71, 87, 0.15);
}

.notify-icon.comment {
  background: rgba(58, 90, 64, 0.15);
}

.notify-icon.follow {
  background: rgba(116, 192, 255, 0.15);
}

.notify-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.notify-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3e2f;
  margin-bottom: 6rpx;
}

.notify-desc {
  font-size: 24rpx;
  color: #6b665e;
  margin-bottom: 6rpx;
}

.notify-time {
  font-size: 22rpx;
  color: #a8a39c;
}

.system-item {
  flex-direction: column;
  align-items: flex-start;
  padding: 30rpx;
}

.system-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3e2f;
  margin-bottom: 10rpx;
}

.system-desc {
  font-size: 24rpx;
  color: #6b665e;
  margin-bottom: 10rpx;
}

.system-time {
  font-size: 22rpx;
  color: #a8a39c;
}