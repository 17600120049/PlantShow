@import "../../styles/detail-page.wxss";
@import "../home/index.wxss";

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 50%, #FAF9F7 100%);
  padding: 0 32rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.load-error {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(196, 120, 90, 0.1);
  color: #9A4A2E;
  border-radius: var(--radius-md);
  font-size: 26rpx;
}

.station-list {
  padding-top: 16rpx;
}

.empty-state {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.join-fixed-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(250, 249, 247, 0) 0%, rgba(250, 249, 247, 0.92) 24%, #FAF9F7 100%);
  box-sizing: border-box;
}

.join-fixed-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
  box-shadow: 0 12rpx 40rpx rgba(45, 71, 57, 0.28);
}

.join-fixed-text {
  flex: 1;
  min-width: 0;
}

.join-fixed-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.join-fixed-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.4;
}

.join-fixed-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}
