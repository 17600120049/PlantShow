.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: var(--page-tab-padding);
}

.header-bg {
  position: relative;
  background: linear-gradient(160deg, #3F5F4E 0%, #1A2E24 100%);
  padding-bottom: 100rpx;
  overflow: hidden;
}

.header-pattern {
  position: absolute;
  top: -60rpx;
  left: -40rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.user-section {
  padding: 32rpx 32rpx 0;
  position: relative;
  z-index: 1;
}

.user-main {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  flex-shrink: 0;
  width: 120rpx !important;
  height: 120rpx !important;
  min-width: 120rpx;
  min-height: 120rpx;
  overflow: hidden;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  margin-left: 24rpx;
  flex-shrink: 1;
  min-width: 0;
  max-width: calc(100% - 144rpx);
}

.nickname-input {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  width: auto;
  min-width: 160rpx;
  max-width: 100%;
  text-align: left !important;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  background: transparent;
}

.nickname-placeholder {
  color: rgba(255, 255, 255, 0.55);
  font-weight: 500;
}

.points-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.points-count {
  font-size: 28rpx;
  color: #D4A017;
  font-weight: 700;
}

.points-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stats-card {
  margin: -56rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  border-radius: var(--radius-lg);
  padding: 36rpx 16rpx;
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-count {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 10rpx;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--color-border);
}

.menu-section {
  padding: 0 32rpx;
}

.menu-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(45, 71, 57, 0.03);
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon-wrap.donate {
  background: rgba(45, 71, 57, 0.08);
}

.menu-icon-wrap.adopt {
  background: rgba(107, 139, 122, 0.12);
}

.menu-icon-wrap.points {
  background: rgba(212, 160, 23, 0.1);
}

.menu-icon-wrap.settings {
  background: rgba(156, 150, 144, 0.1);
}

.menu-icon-wrap.manage {
  background: rgba(63, 95, 78, 0.12);
}

.menu-icon-wrap.open {
  background: rgba(45, 71, 57, 0.1);
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}
