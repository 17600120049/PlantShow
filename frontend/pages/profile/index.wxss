.page {
  min-height: 100vh;
  background: #FDFCFB;
  padding-bottom: 180rpx;
}

.header-bg {
  background: linear-gradient(180deg, #2D4739 0%, #1E3A2F 100%);
  padding-bottom: 80rpx;
}

.user-section {
  padding: 80rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar {
  width: 50rpx;
  height: 50rpx;
  position: relative;
  color: #ffffff;
}

.avatar::before {
  content: '';
  position: absolute;
  width: 24px;
  height: 24px;
  border: 3px solid currentColor;
  border-radius: 50%;
  top: 2px;
  left: 50%;
  transform: translateX(-50%);
}

.avatar::after {
  content: '';
  position: absolute;
  width: 34px;
  height: 18px;
  border: 3px solid currentColor;
  border-top: none;
  border-radius: 0 0 50% 50%;
  bottom: 2px;
  left: 50%;
  transform: translateX(-50%);
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.points-wrap {
  display: flex;
  align-items: center;
}

.points-icon {
  color: #FFD700;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.points-count {
  font-size: 28rpx;
  color: #FFD700;
  font-weight: 600;
}

.points-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.settings-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-btn .icon-settings {
  width: 28rpx;
  height: 28rpx;
  color: #ffffff;
}

.stats-card {
  margin: -40rpx 30rpx 30rpx;
  display: flex;
  background: rgba(253, 252, 251, 0.92);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-count {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D4739;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #8b8680;
  margin-top: 8rpx;
}

.menu-section {
  padding: 0 30rpx;
}

.menu-card {
  background: rgba(253, 252, 251, 0.92);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid rgba(45, 71, 57, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon-wrap.donate {
  background: rgba(45, 71, 57, 0.1);
}

.menu-icon-wrap.adopt {
  background: rgba(139, 173, 144, 0.15);
}

.menu-icon-wrap.points {
  background: rgba(255, 215, 0, 0.1);
}

.menu-icon-wrap.settings {
  background: rgba(139, 134, 128, 0.1);
}

.menu-icon-wrap.donate .icon-plant,
.menu-icon-wrap.adopt .icon-gift,
.menu-icon-wrap.points .icon-star,
.menu-icon-wrap.settings .icon-settings {
  width: 28rpx;
  height: 28rpx;
}

.menu-icon-wrap.donate .icon-plant {
  color: #2D4739;
}

.menu-icon-wrap.adopt .icon-gift {
  color: #6B8B7A;
}

.menu-icon-wrap.points .icon-star {
  color: #B8860B;
}

.menu-icon-wrap.settings .icon-settings {
  color: #8b8680;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  color: #cccccc;
}

.divider {
  height: 20rpx;
  background: #F5F2EE;
}

.about-section {
  padding: 30rpx;
}

.about-title {
  font-size: 26rpx;
  color: #8b8680;
  text-align: center;
}

.about-version {
  font-size: 22rpx;
  color: #b0ab9f;
  text-align: center;
  margin-top: 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8b8680;
  text-align: center;
}