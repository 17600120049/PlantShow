@import "../scan-donate/index.wxss";
@import "../../styles/detail-page.wxss";

.station-header {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
}

.station-logo-wrap {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  margin-right: 24rpx;
  border-radius: var(--radius-md);
}

.station-image {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(145deg, rgba(232, 240, 234, 0.95) 0%, rgba(212, 228, 214, 0.85) 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.station-logo {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius-md);
  display: block;
}

.station-info {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.station-header-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.station-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  flex-shrink: 1;
  min-width: 0;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-status {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-open {
  background: rgba(45, 71, 57, 0.12);
  color: var(--color-primary);
}

.status-closed {
  background: rgba(156, 150, 144, 0.14);
  color: var(--color-text-tertiary);
}

.station-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.station-address-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.station-address {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  flex-shrink: 1;
  min-width: 0;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-nav-icon-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  margin-left: 2rpx;
}

.station-nav-icon-btn:active {
  opacity: 0.65;
}

.station-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--color-text-tertiary);
}

.station-aside {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.station-favorite-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 24rpx rgba(45, 71, 57, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.station-favorite-btn.active {
  background: #ffffff;
  border: 3rpx solid #C4785A;
  box-shadow: 0 8rpx 24rpx rgba(196, 120, 90, 0.24);
}

.station-favorite-icon {
  width: 40rpx;
  height: 40rpx;
}

.station-favorite-btn.active .station-favorite-icon {
  width: 44rpx;
  height: 44rpx;
}

.contact-section {
  padding: 24rpx 28rpx;
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
}

.contact-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-copy {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(45, 71, 57, 0.08);
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.contact-copy:active {
  background: rgba(45, 71, 57, 0.14);
}

.section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin: 8rpx 0 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--color-secondary);
}

.plant-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
}

.plant-emoji,
.plant-photo {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.plant-emoji {
  background: rgba(45, 71, 57, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.plant-detail {
  flex: 1;
  min-width: 0;
}

.plant-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.plant-category {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.plant-time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.empty-card {
  padding: 48rpx 32rpx;
  text-align: center;
  border-radius: var(--radius-lg);
}

.empty-emoji {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.load-error {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(196, 120, 90, 0.1);
  color: #9A4A2E;
  border-radius: var(--radius-md);
  font-size: 26rpx;
}
