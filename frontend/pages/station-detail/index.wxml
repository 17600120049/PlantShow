<view class="page">
  <view class="detail-nav-wrap" style="height: {{navBarBottom}}px;">
    <view
      class="detail-nav-bar"
      style="top: {{navContentTop}}px; height: {{navContentHeight}}px; padding-left: {{navPaddingX}}px; padding-right: {{navPaddingX}}px;"
    >
      <view class="detail-nav-side" style="width: {{navCapsuleWidth}}px;">
        <view class="detail-nav-back-btn" style="width: {{navContentHeight}}px; height: {{navContentHeight}}px;" bindtap="goBack">
          <view class="detail-nav-back-arrow"></view>
        </view>
      </view>
      <view class="detail-nav-title-wrap">
        <text class="detail-nav-title">中转站详情</text>
      </view>
      <view class="detail-nav-side detail-nav-side-placeholder" style="width: {{navCapsuleWidth}}px;"></view>
    </view>
  </view>

  <view class="load-error" wx:if="{{loadError}}">{{loadError}}</view>

  <block wx:if="{{station}}">
    <view class="station-header glass">
      <view class="station-logo-wrap">
        <image wx:if="{{station.logoUrl}}" class="station-logo" src="{{station.logoUrl}}" mode="aspectFill" />
        <view wx:else class="station-image">{{station.image}}</view>
      </view>
      <view class="station-info">
        <view class="station-header-row">
          <text class="station-name">{{station.name}}</text>
          <view class="station-status {{station.isActive ? 'status-open' : 'status-closed'}}">
            {{station.isActive ? '营业中' : '休息中'}}
          </view>
        </view>
        <view class="station-details">
          <view class="station-address-row" wx:if="{{station.address}}">
            <pw-icon name="map-pin" size="24" color="#9C9690" strokeWidth="1.8" />
            <text class="station-address">{{station.address}}</text>
            <view class="station-nav-icon-btn" catchtap="openStationNavigation">
              <pw-icon name="navigation" size="28" color="#3F5F4E" strokeWidth="1.8" />
            </view>
          </view>
          <view class="station-meta" wx:if="{{station.hours}}">
            <view class="meta-item">
              <pw-icon name="clock" size="24" color="#9C9690" strokeWidth="1.8" />
              <text>{{station.hours}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="station-aside">
        <view class="station-favorite-btn {{favorited ? 'active' : ''}}" bindtap="toggleFavorite">
          <image
            class="station-favorite-icon"
            src="{{ favorited ? '/static/icons/tab/heart-active.png' : '/static/icons/tab/heart.png' }}"
            mode="aspectFit"
          />
        </view>
      </view>
    </view>

    <view class="contact-section glass" wx:if="{{station.phone}}">
      <text class="contact-label">联系我们</text>
      <view class="contact-row">
        <text class="contact-text">{{station.contactType === 'WECHAT' ? '微信' : '电话'}}：{{station.phone}}</text>
        <view class="contact-copy" catchtap="copyContact">
          <text>复制</text>
        </view>
      </view>
    </view>

    <view class="section-label">待领养植物（{{plants.length}}）</view>

    <view wx:if="{{plants.length > 0}}">
      <view
        class="plant-item glass"
        wx:for="{{plants}}"
        wx:key="id"
        bindtap="goToPlantDetail"
        data-id="{{item.id}}"
      >
        <image wx:if="{{item.photoUrl}}" class="plant-photo" src="{{item.photoUrl}}" mode="aspectFill" />
        <view wx:else class="plant-emoji">{{item.image}}</view>
        <view class="plant-detail">
          <text class="plant-name">{{item.name}}</text>
          <text class="plant-category">{{item.category}}</text>
          <text class="plant-time">送养于 {{item.donateTime}}</text>
        </view>
        <pw-icon name="chevron-right" size="28" color="#9C9690" strokeWidth="2" />
      </view>
    </view>

    <view class="empty-card glass" wx:else>
      <text class="empty-emoji">🌱</text>
      <text class="empty-title">暂无待领养植物</text>
      <text class="empty-desc">该中转站暂时没有可领养的植物</text>
    </view>
  </block>
</view>
