<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <pw-icon name="chevron-right" size="36" color="#2D4739" strokeWidth="2" class="nav-back-icon" />
      <text class="nav-back-text">返回</text>
    </view>
    <text class="nav-title">中转站详情</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="load-error" wx:if="{{loadError}}">{{loadError}}</view>

  <block wx:if="{{station}}">
    <view class="station-header glass">
      <view class="station-emoji" wx:if="{{station.logoUrl}}">
        <image class="station-logo" src="{{station.logoUrl}}" mode="aspectFill" />
      </view>
      <view class="station-emoji" wx:else>{{station.image}}</view>
      <view class="station-info">
        <view class="station-title-row">
          <text class="station-name">{{station.name}}</text>
          <view class="station-status {{station.isActive ? 'open' : 'closed'}}">
            {{station.isActive ? '营业中' : '休息中'}}
          </view>
        </view>
        <text class="station-address">{{station.address}}</text>
        <text class="station-hours">{{station.hours}}</text>
        <text class="station-phone" wx:if="{{station.phone}}">电话 {{station.phone}}</text>
      </view>
      <image wx:if="{{stationQrUrl}}" class="station-qr" src="{{stationQrUrl}}" mode="aspectFit" />
    </view>

    <view class="section-label">待领养植物（{{plants.length}}）</view>

    <view wx:if="{{plants.length > 0}}">
      <view
        class="plant-item glass"
        wx:for="{{plants}}"
        wx:key="id"
        bindtap="goToPlantDetail"
        data-id="{{item.id}}"
      >
        <image wx:if="{{item.photoUrl}}" class="plant-photo" src="{{item.photoUrl}}" mode="aspectFill" />
        <view wx:else class="plant-emoji">{{item.image}}</view>
        <view class="plant-detail">
          <text class="plant-name">{{item.name}}</text>
          <text class="plant-category">{{item.category}}</text>
          <text class="plant-time">送养于 {{item.donateTime}}</text>
        </view>
        <pw-icon name="chevron-right" size="28" color="#9C9690" strokeWidth="2" />
      </view>
    </view>

    <view class="empty-card glass" wx:else>
      <text class="empty-emoji">🌱</text>
      <text class="empty-title">暂无待领养植物</text>
      <text class="empty-desc">该中转站暂时没有可领养的植物</text>
    </view>
  </block>
</view>
