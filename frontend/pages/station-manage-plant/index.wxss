@import "../../styles/detail-page.wxss";

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 50%, #FAF9F7 100%);
  padding: 0 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.loading-state {
  margin-top: 120rpx;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.load-error,
.readonly-hint {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

.error-panel {
  margin-top: 80rpx;
  padding: 40rpx;
}

.form-panel {
  margin-top: 24rpx;
  padding: 32rpx 28rpx;
  border-radius: var(--radius-xl);
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.required {
  color: #9A4A2E;
}

.readonly-value {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid var(--color-border);
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid var(--color-border);
  font-size: 28rpx;
}

.radio-row {
  display: flex;
  gap: 32rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.photo-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(45, 71, 57, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-tertiary);
}

.primary-btn {
  margin-top: 12rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-btn::after {
  border: none;
}
