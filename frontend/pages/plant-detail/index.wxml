<view class="page">
  <view class="detail-nav-wrap" style="height: {{navBarBottom}}px;">
    <view
      class="detail-nav-bar"
      style="top: {{navContentTop}}px; height: {{navContentHeight}}px; padding-left: {{navPaddingX}}px; padding-right: {{navPaddingX}}px;"
    >
      <view class="detail-nav-side" style="width: {{navCapsuleWidth}}px;">
        <view class="detail-nav-back-btn" style="width: {{navContentHeight}}px; height: {{navContentHeight}}px;" bindtap="goBack">
          <view class="detail-nav-back-arrow"></view>
        </view>
      </view>
      <view class="detail-nav-title-wrap">
        <text class="detail-nav-title">植物详情</text>
      </view>
      <view class="detail-nav-side detail-nav-side-placeholder" style="width: {{navCapsuleWidth}}px;"></view>
    </view>
  </view>

  <view class="load-error" wx:if="{{loadError}}">{{loadError}}</view>

  <block wx:if="{{plant}}">
    <view class="hero-card glass detail-card-with-favorite">
      <view class="detail-favorite-btn {{favorited ? 'active' : ''}}" bindtap="toggleFavorite">
        <image
          class="detail-favorite-icon"
          src="{{ favorited ? '/static/icons/tab/heart-active.png' : '/static/icons/tab/heart.png' }}"
          mode="aspectFit"
        />
      </view>
      <image wx:if="{{currentPhoto || plant.photoUrl}}" class="hero-photo" src="{{currentPhoto || plant.photoUrl}}" mode="aspectFill" />
      <view wx:else class="hero-emoji">{{plant.image}}</view>
      <view class="hero-info">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-category">{{plant.category}}</text>
        <view class="status-tag">{{plant.status}}</view>
      </view>
    </view>

    <scroll-view class="photo-scroll" scroll-x wx:if="{{plant.photos.length > 1}}" enhanced show-scrollbar="{{false}}">
      <image
        class="photo-thumb {{currentPhoto === item ? 'active' : ''}}"
        wx:for="{{plant.photos}}"
        wx:key="*this"
        src="{{item}}"
        mode="aspectFill"
        bindtap="setCurrentPhoto"
        data-url="{{item}}"
      />
    </scroll-view>

    <view class="info-card glass">
      <view class="info-row">
        <text class="info-label">植物编号</text>
        <text class="info-value code">{{plant.plantCode}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.station}}">
        <text class="info-label">所在中转站</text>
        <text class="info-value link" bindtap="goToStation">{{plant.station}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.donorName}}">
        <text class="info-label">送养人</text>
        <text class="info-value">{{plant.donorName}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.donateTime}}">
        <text class="info-label">送养时间</text>
        <text class="info-value">{{plant.donateTime}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.description}}">
        <text class="info-label">描述</text>
        <text class="info-value desc">{{plant.description}}</text>
      </view>
    </view>
  </block>
</view>
