<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <pw-icon name="chevron-right" size="36" color="#2D4739" strokeWidth="2" class="nav-back-icon" />
      <text class="nav-back-text">返回</text>
    </view>
    <text class="nav-title">植物详情</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="load-error" wx:if="{{loadError}}">{{loadError}}</view>

  <block wx:if="{{plant}}">
    <view class="hero-card glass">
      <image wx:if="{{currentPhoto || plant.photoUrl}}" class="hero-photo" src="{{currentPhoto || plant.photoUrl}}" mode="aspectFill" />
      <view wx:else class="hero-emoji">{{plant.image}}</view>
      <view class="hero-info">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-category">{{plant.category}}</text>
        <view class="status-tag">{{plant.status}}</view>
      </view>
    </view>

    <scroll-view class="photo-scroll" scroll-x wx:if="{{plant.photos.length > 1}}" enhanced show-scrollbar="{{false}}">
      <image
        class="photo-thumb {{currentPhoto === item ? 'active' : ''}}"
        wx:for="{{plant.photos}}"
        wx:key="*this"
        src="{{item}}"
        mode="aspectFill"
        bindtap="setCurrentPhoto"
        data-url="{{item}}"
      />
    </scroll-view>

    <view class="info-card glass">
      <view class="info-row">
        <text class="info-label">植物编号</text>
        <text class="info-value code">{{plant.plantCode}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.station}}">
        <text class="info-label">所在中转站</text>
        <text class="info-value link" bindtap="goToStation">{{plant.station}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.donateTime}}">
        <text class="info-label">送养时间</text>
        <text class="info-value">{{plant.donateTime}}</text>
      </view>
      <view class="info-row" wx:if="{{plant.description}}">
        <text class="info-label">描述</text>
        <text class="info-value desc">{{plant.description}}</text>
      </view>
    </view>
  </block>
</view>
