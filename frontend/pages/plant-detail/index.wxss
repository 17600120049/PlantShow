@import "../scan-donate/index.wxss";

.hero-card {
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
}

.hero-photo,
.hero-emoji {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.hero-emoji {
  background: rgba(45, 71, 57, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
}

.hero-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.plant-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.plant-category {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.status-tag {
  align-self: flex-start;
  margin-top: 16rpx;
  padding: 6rpx 20rpx;
  background: rgba(45, 71, 57, 0.1);
  color: var(--color-primary);
  border-radius: 999rpx;
  font-size: 24rpx;
}

.info-card {
  padding: 8rpx 28rpx;
  border-radius: var(--radius-lg);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text);
  text-align: right;
}

.info-value.code {
  font-family: monospace;
}

.info-value.desc {
  line-height: 1.5;
}

.info-value.link {
  color: var(--color-primary);
}

.load-error {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(196, 120, 90, 0.1);
  color: #9A4A2E;
  border-radius: var(--radius-md);
  font-size: 26rpx;
}

.photo-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.photo-thumb {
  display: inline-block;
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  margin-right: 16rpx;
  border: 3rpx solid transparent;
}

.photo-thumb.active {
  border-color: var(--color-primary);
}
