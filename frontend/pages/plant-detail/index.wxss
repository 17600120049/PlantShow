/* pages/plant-detail/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FDFCFB 0%, #F5F2EE 100%);
  padding-bottom: 200rpx;
}

.navbar {
  background: transparent;
  padding-top: 60rpx;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(253, 252, 251, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.back-icon {
  font-size: 32rpx;
  color: #2D4739;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D4739;
}

.share-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(253, 252, 251, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.share-icon {
  font-size: 32rpx;
  color: #2D4739;
}

.plant-hero {
  position: relative;
  width: 100%;
  height: 500rpx;
  background: linear-gradient(135deg, #E8F0E9 0%, #D4E4D0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plant-emoji {
  font-size: 200rpx;
}

.plant-tag {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.tag-trade {
  background: rgba(45, 71, 57, 0.85);
  color: #ffffff;
}

.tag-free {
  background: rgba(253, 252, 251, 0.95);
  color: #2D4739;
}

.plant-info-card {
  margin: -40rpx 30rpx 30rpx;
  padding: 40rpx;
  background: rgba(253, 252, 251, 0.98);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.plant-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D4739;
  margin-bottom: 12rpx;
}

.plant-desc {
  font-size: 28rpx;
  color: #6b665e;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.plant-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #8b8680;
}

.meta-icon {
  margin-right: 8rpx;
}

.author-section {
  display: flex;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #8DA390 0%, #7A9182 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D4739;
  margin-bottom: 4rpx;
}

.author-id {
  font-size: 22rpx;
  color: #8b8680;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: #FDFCFB;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary {
  background: #2D4739;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(45, 71, 57, 0.35);
}

.btn-secondary {
  background: rgba(45, 71, 57, 0.1);
  color: #2D4739;
  border: 1rpx solid rgba(45, 71, 57, 0.2);
}

.detail-section {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background: rgba(253, 252, 251, 0.98);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D4739;
  margin-bottom: 20rpx;
}

.detail-content {
  font-size: 26rpx;
  color: #6b665e;
  line-height: 1.8;
}

.detail-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.detail-image {
  width: calc(50% - 8rpx);
  height: 240rpx;
  background: linear-gradient(135deg, #E8F0E9 0%, #D4E4D0 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}
