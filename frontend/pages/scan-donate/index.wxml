<view class="page">
  <view class="detail-nav-wrap" style="height: {{navBarBottom}}px;">
    <view
      class="detail-nav-bar"
      style="top: {{navContentTop}}px; height: {{navContentHeight}}px; padding-left: {{navPaddingX}}px; padding-right: {{navPaddingX}}px;"
    >
      <view class="detail-nav-side" style="width: {{navCapsuleWidth}}px;">
        <view class="detail-nav-back-btn" style="width: {{navContentHeight}}px; height: {{navContentHeight}}px;" bindtap="goBack">
          <view class="detail-nav-back-arrow"></view>
        </view>
      </view>
      <view class="detail-nav-title-wrap">
        <text class="detail-nav-title">扫码送养</text>
      </view>
      <view class="detail-nav-side detail-nav-side-placeholder" style="width: {{navCapsuleWidth}}px;"></view>
    </view>
  </view>

  <!-- 引导页 -->
  <block wx:if="{{step === 'intro'}}">
    <view class="hero">
      <view class="hero-icon-wrap">
        <pw-icon name="qr-code" size="80" color="#FFFFFF" strokeWidth="1.8" />
      </view>
      <text class="hero-title">扫码送养植物</text>
      <text class="hero-desc">扫描中转站二维码，登记植物信息并送养</text>
    </view>

    <view class="action-card glass">
      <button class="scan-btn" bindtap="startScan" loading="{{scanning}}" disabled="{{scanning}}">
        <pw-icon name="qr-code" size="40" color="#FFFFFF" strokeWidth="2" />
        <text>{{scanning ? '扫描中...' : '扫描中转站二维码'}}</text>
      </button>
    </view>

    <view class="guide-card glass">
      <text class="guide-title">送养流程</text>
      <view class="guide-step">
        <text class="step-num">1</text>
        <text class="step-text">扫描中转站门口的二维码</text>
      </view>
      <view class="guide-step">
        <text class="step-num">2</text>
        <text class="step-text">填写植物信息并上传照片</text>
      </view>
      <view class="guide-step">
        <text class="step-num">3</text>
        <text class="step-text">完成送养，植物自动归属该中转站</text>
      </view>
    </view>
  </block>

  <!-- 填写表单 -->
  <block wx:if="{{step === 'form'}}">
    <view class="station-header glass">
      <view class="station-emoji" wx:if="{{station.logoUrl}}">
        <image class="station-logo" src="{{station.logoUrl}}" mode="aspectFill" />
      </view>
      <view class="station-emoji" wx:else>{{station.image}}</view>
      <view class="station-info">
        <text class="station-name">{{station.name}}</text>
        <text class="station-address">{{station.address}}</text>
        <text class="station-hours">{{station.hours}}</text>
        <text class="station-tip">植物将送养至此中转站</text>
      </view>
      <image wx:if="{{stationQrUrl}}" class="station-qr" src="{{stationQrUrl}}" mode="aspectFit" />
    </view>

    <view class="form-card glass">
      <view class="form-item">
        <text class="label">植物名称 <text class="required">*</text></text>
        <input class="input" placeholder="给植物起个名字" value="{{plantName}}" bindinput="onPlantNameInput" />
      </view>

      <view class="form-item">
        <text class="label">植物品种 <text class="required">*</text></text>
        <input class="input" placeholder="例如：绿萝、多肉、蕨类" value="{{plantCategory}}" bindinput="onPlantCategoryInput" />
      </view>

      <view class="form-item">
        <text class="label">植物描述</text>
        <textarea class="textarea" placeholder="养护经验、注意事项等..." value="{{plantDescription}}" bindinput="onPlantDescriptionInput" maxlength="300" />
      </view>

      <view class="form-item">
        <text class="label">植物照片 <text class="required">*</text></text>
        <view class="image-row">
          <view class="image-preview" wx:if="{{images.length > 0}}">
            <image src="{{images[0]}}" mode="aspectFill" />
            <view class="image-delete" bindtap="deleteImage">×</view>
          </view>
          <view class="image-add" bindtap="chooseImage" wx:else>
            <text class="add-icon">+</text>
            <text class="add-text">添加照片</text>
          </view>
        </view>
      </view>
    </view>

    <button class="primary-btn" bindtap="goToConfirm">下一步</button>
  </block>

  <!-- 确认页 -->
  <block wx:if="{{step === 'confirm'}}">
    <view class="confirm-card glass">
      <view class="confirm-plant">
        <image wx:if="{{images[0]}}" class="confirm-photo" src="{{images[0]}}" mode="aspectFill" />
        <view wx:else class="confirm-emoji">{{plantImage}}</view>
        <view class="confirm-info">
          <text class="confirm-name">{{plantName}}</text>
          <text class="confirm-category">{{plantCategory}}</text>
        </view>
      </view>
      <view class="confirm-row">
        <text class="confirm-label">送养中转站</text>
        <text class="confirm-value">{{station.name}}</text>
      </view>
      <view class="confirm-row" wx:if="{{plantDescription}}">
        <text class="confirm-label">描述</text>
        <text class="confirm-value desc">{{plantDescription}}</text>
      </view>
      <view class="points-tip">
        <pw-icon name="star" size="28" color="#D4A017" filled="{{true}}" />
        <text>完成送养可获得 10 积分</text>
      </view>
    </view>

    <button class="primary-btn" bindtap="submitDonate" loading="{{submitting}}" disabled="{{submitting}}">确认送养</button>
    <button class="secondary-btn" bindtap="goBack">返回修改</button>
  </block>

  <!-- 成功页 -->
  <block wx:if="{{step === 'success'}}">
    <view class="success-card glass">
      <view class="success-icon">✓</view>
      <text class="success-title">送养成功</text>
      <text class="success-desc">「{{result.plant.name}}」已送至「{{result.station.name}}」</text>
      <view class="success-points">
        <text class="points-earned">+{{result.points}}</text>
        <text class="points-total">当前积分 {{result.totalPoints}}</text>
      </view>
      <view class="qr-section" wx:if="{{result.qrImageUrl}}">
        <text class="qr-label">植物二维码标签</text>
        <image class="qr-image" src="{{result.qrImageUrl}}" mode="aspectFit" show-menu-by-longpress="{{true}}" />
        <text class="qr-tip">可长按保存，打印贴于花盆供领养者扫描</text>
      </view>
    </view>
    <button class="primary-btn" bindtap="goHome">返回首页</button>
    <button class="secondary-btn" bindtap="donateAgain">继续送养</button>
  </block>
</view>
