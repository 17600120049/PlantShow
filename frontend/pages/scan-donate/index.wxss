.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF9F7 0%, #F3F0EB 100%);
  padding: 0 32rpx 80rpx;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  margin-bottom: 24rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  min-width: 120rpx;
}

.nav-back-icon {
  transform: rotate(180deg);
  margin-right: 4rpx;
}

.nav-back-text {
  font-size: 28rpx;
  color: var(--color-primary);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.nav-placeholder {
  min-width: 120rpx;
}

.hero {
  background: linear-gradient(145deg, #3F5F4E 0%, #1A2E24 100%);
  border-radius: var(--radius-xl);
  padding: 64rpx 40rpx;
  text-align: center;
  box-shadow: var(--shadow-lg);
}

.hero-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.78);
}

.action-card {
  margin-top: 32rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg);
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #3F5F4E 0%, #2D4739 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(45, 71, 57, 0.3);
}

.scan-btn::after {
  border: none;
}

.manual-link {
  margin-top: 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-secondary);
}

.manual-box {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.manual-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: rgba(139, 134, 128, 0.08);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
}

.manual-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-sm);
}

.manual-btn::after {
  border: none;
}

.guide-card {
  margin-top: 32rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg);
}

.guide-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.guide-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.guide-step:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.demo-card {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
}

.demo-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
}

.demo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.demo-item {
  padding: 16rpx 28rpx;
  background: rgba(45, 71, 57, 0.08);
  color: var(--color-primary);
  font-size: 26rpx;
  border-radius: 999rpx;
}

.form-card,
.confirm-card,
.success-card {
  padding: 32rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 32rpx;
}

.code-badge {
  background: rgba(45, 71, 57, 0.06);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.code-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 4rpx;
}

.code-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  font-family: monospace;
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.required {
  color: var(--color-accent);
}

.input,
.picker-value {
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(139, 134, 128, 0.08);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx 24rpx;
  background: rgba(139, 134, 128, 0.08);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  box-sizing: border-box;
}

.image-row {
  display: flex;
}

.image-preview,
.image-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 28rpx;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(139, 134, 128, 0.08);
  border: 2rpx dashed rgba(45, 71, 57, 0.2);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-tertiary);
}

.add-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.primary-btn {
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #3F5F4E 0%, #2D4739 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(45, 71, 57, 0.25);
}

.primary-btn::after {
  border: none;
}

.secondary-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: transparent;
  color: var(--color-text-secondary);
  font-size: 28rpx;
  border: none;
}

.secondary-btn::after {
  border: none;
}

.confirm-plant {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.confirm-emoji {
  width: 100rpx;
  height: 100rpx;
  background: rgba(45, 71, 57, 0.06);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.confirm-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.confirm-category {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.confirm-code {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
  font-family: monospace;
}

.confirm-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  gap: 24rpx;
}

.confirm-label {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.confirm-value {
  font-size: 28rpx;
  color: var(--color-text);
  text-align: right;
}

.confirm-value.desc {
  flex: 1;
  line-height: 1.5;
}

.points-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(212, 160, 23, 0.1);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: #9A7B0A;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, #3F5F4E, #2D4739);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
}

.success-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.success-desc {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

.success-points {
  text-align: center;
  padding: 24rpx;
  background: rgba(212, 160, 23, 0.1);
  border-radius: var(--radius-sm);
}

.points-earned {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #D4A017;
}

.points-total {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.qr-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--color-border);
  text-align: center;
}

.qr-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
}

.qr-image {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto;
  display: block;
  border-radius: var(--radius-sm);
  background: #fff;
  padding: 16rpx;
  box-shadow: var(--shadow-sm);
}

.qr-tip {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 16rpx;
}

.station-header {
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 32rpx;
}

.station-emoji {
  width: 88rpx;
  height: 88rpx;
  background: rgba(45, 71, 57, 0.1);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.station-info {
  flex: 1;
  min-width: 0;
}

.station-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.station-address {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.station-hours {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.station-tip {
  display: block;
  font-size: 24rpx;
  color: var(--color-primary);
  margin-top: 10rpx;
  font-weight: 500;
}

.station-qr {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  background: #fff;
  padding: 8rpx;
}

.station-logo {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.confirm-photo {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
