@import "../scan-donate/index.wxss";
@import "../../styles/detail-page.wxss";

.hero {
  text-align: left;
  padding: 40rpx 36rpx;
}

.philosophy-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 28rpx;
}

.philosophy-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.philosophy-item:last-child {
  margin-bottom: 0;
}

.philosophy-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  margin-top: 14rpx;
  flex-shrink: 0;
}

.philosophy-text {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.7;
}

.form-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.form-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.success-card {
  margin-top: 48rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  border-radius: var(--radius-xl);
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3F5F4E 0%, #2D4739 100%);
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
