<!--pages/publish/index.wxml-->
<view class="container">
  <!-- 发布类型切换 -->
  <view class="type-tabs">
    <view class="tab-item {{postType === 'plant' ? 'active' : ''}}" 
          data-type="plant" 
          bindtap="onTypeChange">
      发布植物
    </view>
    <view class="tab-item {{postType === 'moment' ? 'active' : ''}}" 
          data-type="moment" 
          bindtap="onTypeChange">
      发布动态
    </view>
  </view>

  <!-- 发布植物表单 -->
  <view class="form-section" wx:if="{{postType === 'plant'}}">
    <view class="form-item">
      <view class="label">植物名称 <text class="required">*</text></view>
      <input class="input" 
             placeholder="给植物起个名字" 
             value="{{plantName}}" 
             bindinput="onPlantNameInput" />
    </view>

    <view class="form-item">
      <view class="label">植物品种 <text class="required">*</text></view>
      <input class="input" 
             placeholder="例如：绿萝、多肉、玫瑰" 
             value="{{plantSpecies}}" 
             bindinput="onPlantSpeciesInput" />
    </view>

    <view class="form-item">
      <view class="label">植物年龄</view>
      <input class="input" 
             placeholder="例如：3个月、1年" 
             value="{{plantAge}}" 
             bindinput="onPlantAgeInput" />
    </view>

    <view class="form-item">
      <view class="label">所在位置</view>
      <view class="location-picker" bindtap="chooseLocation">
        <text class="location-text">{{plantLocation || '点击选择位置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="form-item">
      <view class="label">植物描述</view>
      <textarea class="textarea" 
                placeholder="介绍一下这株植物的特点、养护经验等..." 
                value="{{plantDescription}}" 
                bindinput="onPlantDescriptionInput" 
                maxlength="500" />
      <view class="char-count">{{plantDescription.length}}/500</view>
    </view>
  </view>

  <!-- 发布动态表单 -->
  <view class="form-section" wx:if="{{postType === 'moment'}}">
    <view class="form-item">
      <view class="label">动态内容 <text class="required">*</text></view>
      <textarea class="textarea large" 
                placeholder="分享你的植物故事、养护心得..." 
                value="{{momentContent}}" 
                bindinput="onMomentContentInput" 
                maxlength="1000" />
      <view class="char-count">{{momentContent.length}}/1000</view>
    </view>
  </view>

  <!-- 图片上传区域 -->
  <view class="image-section">
    <view class="section-title">添加图片</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="image" src="{{item}}" mode="aspectFill" />
        <view class="delete-btn" 
              catchtap="deleteImage" 
              data-index="{{index}}">
          ×
        </view>
      </view>
      <view class="image-add" 
            bindtap="chooseImage" 
            wx:if="{{images.length < 9}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
    <view class="image-tip">最多上传9张图片</view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="submitPublish">
      发布
    </button>
  </view>
</view>
