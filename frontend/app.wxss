@import './styles/theme.wxss';

page {
  font-family: var(--font-body);
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

view, text {
  box-sizing: border-box;
}

image {
  display: block;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  outline: none;
}

button::after {
  border: none;
}

scroll-view {
  -webkit-overflow-scrolling: touch;
}
